<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} — Joetsu-Myoko Daily" : "Joetsu-Myoko Daily — Local News in English" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#030712" media="(prefers-color-scheme: dark)">
    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "English-language local news for Joetsu, Myoko, and the surrounding region in Niigata, Japan." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# No-flash dark-mode: must run before stylesheets so the `dark` class is
        present on <html> at first paint. Reads the user's stored preference
        ("light"/"dark"/"system") and falls through to the OS preference. %>
    <%= javascript_tag nonce: true do %>
      (function() {
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (stored === "dark" || (stored !== "light" && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch (e) {}
      })();
    <% end %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link rel="canonical" href="<%= content_for?(:canonical_url) ? yield(:canonical_url) : canonical_url_for_current_request %>">

    <% if content_for?(:meta_robots) %>
      <meta name="robots" content="<%= yield(:meta_robots) %>">
    <% end %>

    <% alternate_locale_urls.each do |code, url| %>
      <link rel="alternate" hreflang="<%= code %>" href="<%= url %>">
    <% end %>

    <%= render "shared/site_jsonld" %>

    <!-- Open Graph -->
    <meta property="og:site_name" content="Joetsu-Myoko Daily">
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : "Joetsu-Myoko Daily" %>">
    <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "English-language local news for Joetsu, Myoko, and the surrounding region." %>">
    <meta property="og:type" content="<%= content_for?(:og_type) ? yield(:og_type) : "website" %>">
    <% if content_for?(:og_image) %>
      <meta property="og:image" content="<%= yield(:og_image) %>">
    <% end %>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : "Joetsu-Myoko Daily" %>">
    <meta name="twitter:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : "English-language local news for Joetsu, Myoko, and the surrounding region." %>">
    <% if content_for?(:og_image) %>
      <meta name="twitter:image" content="<%= yield(:og_image) %>">
    <% end %>

    <%= yield(:head) if content_for?(:head) %>

    <link rel="alternate" type="application/rss+xml" title="Joetsu-Myoko Daily (English)" href="<%= feed_url(format: :rss, locale: 'en') %>">
    <link rel="alternate" type="application/rss+xml" title="上越妙高デイリー (日本語)" href="<%= feed_url(format: :rss, locale: 'ja') %>">
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-indigo-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:outline-2 focus:outline-offset-2 focus:outline-white">
      Skip to content
    </a>

    <%= render "shared/header" %>

    <%= render "shared/breaking_banner" %>

    <% if notice %>
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pt-4">
        <div class="rounded-md bg-green-50 border border-green-200 p-4 dark:bg-green-950/40 dark:border-green-900" role="status">
          <p class="text-sm text-green-800 dark:text-green-200"><%= notice %></p>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pt-4">
        <div class="rounded-md bg-red-50 border border-red-200 p-4 dark:bg-red-950/40 dark:border-red-900" role="alert">
          <p class="text-sm text-red-800 dark:text-red-200"><%= alert %></p>
        </div>
      </div>
    <% end %>

    <main id="main" class="min-h-screen">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
