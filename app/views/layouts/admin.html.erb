<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
<head>
  <title><%= content_for?(:title) ? "#{yield(:title)} — JMDaily Admin" : "JMDaily Admin" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full">
  <% if current_user %>
    <div class="min-h-full">
      <nav class="bg-gray-800">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <span class="text-white font-bold text-lg">JMDaily Admin</span>
              </div>
              <div class="ml-10 flex items-baseline space-x-4">
                <%= link_to "Articles", admin_articles_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "Categories", admin_categories_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "Tags", admin_tags_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "Locations", admin_locations_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "Authors", admin_authors_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "Pages", admin_static_pages_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "Ads", admin_ads_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white" %>
                <%= link_to "View Site →", root_path, class: "rounded-md px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white", target: "_blank" %>
              </div>
            </div>
            <div class="flex items-center space-x-4">
              <span class="text-gray-300 text-sm"><%= current_user.name %></span>
              <%= button_to "Log out", admin_logout_path, method: :delete, class: "rounded-md bg-gray-700 px-3 py-2 text-sm font-medium text-gray-300 hover:bg-gray-600 hover:text-white" %>
            </div>
          </div>
        </div>
      </nav>

      <main>
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
          <% if notice %>
            <div class="mb-4 rounded-md bg-green-50 p-4">
              <p class="text-sm text-green-700"><%= notice %></p>
            </div>
          <% end %>
          <% if alert %>
            <div class="mb-4 rounded-md bg-red-50 p-4">
              <p class="text-sm text-red-700"><%= alert %></p>
            </div>
          <% end %>
          <%= yield %>
        </div>
      </main>
    </div>
  <% else %>
    <div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
      <% if alert %>
        <div class="sm:mx-auto sm:w-full sm:max-w-sm mb-4 rounded-md bg-red-50 p-4">
          <p class="text-sm text-red-700"><%= alert %></p>
        </div>
      <% end %>
      <%= yield %>
    </div>
  <% end %>
</body>
</html>
