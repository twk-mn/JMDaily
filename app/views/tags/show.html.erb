<% content_for :title, "Tagged: #{@tag.name}" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/index_header",
      title: "Tagged: #{@tag.name}",
      count: @pagy.count,
      breadcrumbs: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: @tag.name, url: request.path }
      ] %>

  <% if @articles.any? %>
    <div class="space-y-8">
      <% @articles.each do |article| %>
        <%= render "shared/article_card", article: article %>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  <% else %>
    <%= render "shared/empty_state",
        heading: "No articles with this tag yet.",
        body: "Try another tag or browse the latest news." %>
  <% end %>
</div>
