<% content_for :title, "Tagged: #{@tag.name}" %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900" style="font-family: Georgia, serif;">Tagged: <%= @tag.name %></h1>
  </header>

  <div class="space-y-8">
    <% @articles.each do |article| %>
      <%= render "shared/article_card", article: article %>
    <% end %>
  </div>

  <% if @articles.empty? %>
    <p class="text-center py-16 text-gray-500">No articles with this tag yet.</p>
  <% end %>

  <% if @pagy.pages > 1 %>
    <nav class="mt-8 flex justify-center">
      <%== @pagy.series_nav(self) %>
    </nav>
  <% end %>
</div>
