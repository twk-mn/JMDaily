<% content_for :title, "Activity Log" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Activity Log</h1>
  <p class="text-sm text-gray-400">Showing last 200 entries</p>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">When</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Who</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Resource</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">IP</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @audit_logs.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-400">No activity recorded yet.</td>
        </tr>
      <% end %>
      <% @audit_logs.each do |log| %>
        <tr>
          <td class="px-6 py-3 text-xs text-gray-400 whitespace-nowrap">
            <time datetime="<%= log.created_at.iso8601 %>" title="<%= log.created_at.strftime("%-d %b %Y %H:%M:%S UTC") %>">
              <%= log.created_at.strftime("%-d %b %Y, %-I:%M %p") %>
            </time>
          </td>
          <td class="px-6 py-3 text-sm text-gray-700">
            <%= log.user&.name || "<em class='text-gray-400'>deleted user</em>".html_safe %>
          </td>
          <td class="px-6 py-3 text-sm">
            <% badge_class = case log.action
               when "create"  then "bg-green-100 text-green-800"
               when "update"  then "bg-blue-100 text-blue-800"
               when "destroy" then "bg-red-100 text-red-800"
               else "bg-gray-100 text-gray-600"
               end %>
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= badge_class %>">
              <%= log.action %>
            </span>
          </td>
          <td class="px-6 py-3 text-sm text-gray-700">
            <span class="text-gray-400 text-xs"><%= log.resource_type %></span>
            <span class="ml-1"><%= log.resource_label %></span>
          </td>
          <td class="px-6 py-3 text-xs text-gray-400 font-mono"><%= log.ip_address %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
