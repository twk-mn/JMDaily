<% content_for :title, "Preview: #{@issue.subject}" %>

<div class="mb-4 flex items-center justify-between">
  <h1 class="text-xl font-bold text-gray-900">Email preview — <%= @issue.subject %></h1>
  <%= link_to "← Back", edit_admin_newsletter_issue_path(@issue), class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>

<div class="border border-gray-200 rounded-lg overflow-hidden shadow-sm">
  <iframe srcdoc="<%= html_escape(@email_html) %>"
          sandbox="allow-same-origin"
          style="width: 100%; height: 800px; border: none;"
          title="Email preview"></iframe>
</div>
