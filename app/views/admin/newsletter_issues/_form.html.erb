<% content_for :title, issue.persisted? ? "Edit Issue" : "New Issue" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= issue.persisted? ? "Edit Issue" : "New Newsletter Issue" %></h1>
</div>

<%= form_with model: [ :admin, issue ], class: "space-y-6 max-w-3xl" do |f| %>
  <% if issue.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc pl-5 text-sm text-red-700">
        <% issue.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 space-y-5">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="sm:col-span-2">
        <%= f.label :subject, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :subject, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-2 border", autofocus: true %>
      </div>
      <div>
        <%= f.label :locale, "Language", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :locale,
            [["🇬🇧 English", "en"], ["🇯🇵 Japanese", "ja"]],
            {},
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-2 border" %>
        <p class="mt-1 text-xs text-gray-500">Sets the language of links in the email.</p>
      </div>
    </div>

    <div>
      <%= f.label :body, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <p class="text-xs text-gray-500 mb-2">Plain text. Paragraphs are separated by blank lines.</p>
      <%= f.text_area :body, rows: 20, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-2 border font-mono" %>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= f.submit issue.persisted? ? "Save changes" : "Save draft",
        class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer" %>
    <% if issue.persisted? %>
      <%= link_to "Preview email →", preview_admin_newsletter_issue_path(issue), target: "_blank",
          class: "text-sm text-gray-500 hover:text-gray-700" %>
    <% end %>
    <%= link_to "Cancel", admin_newsletter_issues_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
