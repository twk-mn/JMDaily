<% content_for :title, "Articles" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Articles</h1>
  <%= link_to "New Article", new_admin_article_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</div>

<!-- Filters -->
<div class="mb-6 bg-white rounded-lg shadow p-4">
  <%= form_with url: admin_articles_path, method: :get, class: "flex flex-wrap gap-4 items-end" do |f| %>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :status, options_for_select(Article::STATUSES.map { |s| [s.titleize, s] }, params[:status]),
          { include_blank: "All statuses" },
          class: "mt-1 block rounded-md border-gray-300 shadow-sm text-sm px-2 py-1.5 border" %>
    </div>
    <div>
      <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :category_id, options_from_collection_for_select(Category.all, :id, :name, params[:category_id]),
          { include_blank: "All categories" },
          class: "mt-1 block rounded-md border-gray-300 shadow-sm text-sm px-2 py-1.5 border" %>
    </div>
    <div>
      <%= f.label :q, "Search", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :q, value: params[:q], placeholder: "Search titles...",
          class: "mt-1 block rounded-md border-gray-300 shadow-sm text-sm px-2 py-1.5 border" %>
    </div>
    <div>
      <%= f.submit "Filter", class: "rounded-md bg-gray-200 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-300 cursor-pointer" %>
      <%= link_to "Clear", admin_articles_path, class: "ml-2 text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Author</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Updated</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @articles.each do |article| %>
        <tr>
          <td class="px-6 py-4">
            <div class="text-sm font-medium text-gray-900">
              <%= link_to article.title, edit_admin_article_path(article), class: "hover:text-indigo-600" %>
            </div>
            <div class="text-sm text-gray-500"><%= article.dek&.truncate(80) %></div>
            <% if article.featured? %>
              <span class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">Featured</span>
            <% end %>
            <% if article.breaking? %>
              <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800">Breaking</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% status_colors = { "draft" => "bg-gray-100 text-gray-800", "scheduled" => "bg-blue-100 text-blue-800", "published" => "bg-green-100 text-green-800", "archived" => "bg-yellow-100 text-yellow-800" } %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= status_colors[article.status] %>">
              <%= article.status.titleize %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= article.category.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= article.author.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= article.updated_at.strftime("%b %d, %Y %H:%M") %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <%= link_to "Edit", edit_admin_article_path(article), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @articles.empty? %>
    <div class="text-center py-12 text-gray-500">
      <p class="text-lg">No articles found.</p>
      <p class="mt-2"><%= link_to "Create your first article", new_admin_article_path, class: "text-indigo-600 hover:text-indigo-500" %></p>
    </div>
  <% end %>
</div>

<% if @pagy && @pagy.pages > 1 %>
  <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
    <span><%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %> articles</span>
    <nav class="flex gap-1">
      <% if @pagy.prev %>
        <%= link_to "← Previous", admin_articles_path(request.query_parameters.merge(page: @pagy.prev)),
            class: "px-3 py-1.5 rounded border border-gray-300 bg-white hover:bg-gray-50" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Next →", admin_articles_path(request.query_parameters.merge(page: @pagy.next)),
            class: "px-3 py-1.5 rounded border border-gray-300 bg-white hover:bg-gray-50" %>
      <% end %>
    </nav>
  </div>
<% end %>
