<div data-nested-fields-target="row" class="flex items-start gap-3 p-3 bg-gray-50 rounded-md">
  <%= cf.hidden_field :id %>
  <%= cf.hidden_field :_destroy, value: "0" %>
  <div class="flex-1 grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div class="sm:col-span-2">
      <%= cf.label :body, "Correction", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= cf.text_area :body, rows: 2,
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-1.5 border",
          placeholder: "What was wrong, and what's the corrected version" %>
    </div>
    <div>
      <%= cf.label :posted_at, "Posted at", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= cf.datetime_local_field :posted_at,
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-1.5 border" %>
      <p class="mt-1 text-xs text-gray-500">Defaults to now if blank.</p>
    </div>
  </div>
  <div class="pt-5">
    <button type="button"
            data-action="nested-fields#remove"
            class="text-xs text-red-500 hover:text-red-700">Remove</button>
  </div>
</div>
