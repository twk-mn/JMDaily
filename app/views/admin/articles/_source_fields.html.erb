<div data-nested-fields-target="row" class="flex items-start gap-3 p-3 bg-gray-50 rounded-md">
  <%= sf.hidden_field :id %>
  <%= sf.hidden_field :_destroy, value: "0" %>
  <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div>
      <%= sf.label :name, "Source name", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= sf.text_field :name,
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-1.5 border",
          placeholder: "e.g. Niigata Nippo" %>
    </div>
    <div>
      <%= sf.label :url, "URL (optional)", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= sf.url_field :url,
          class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-1.5 border",
          placeholder: "https://..." %>
    </div>
  </div>
  <div class="pt-5">
    <button type="button"
            data-action="nested-fields#remove"
            class="text-xs text-red-500 hover:text-red-700">Remove</button>
  </div>
</div>
