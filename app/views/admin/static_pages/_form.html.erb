<% content_for :title, page.persisted? ? "Edit Page" : "New Page" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6"><%= page.persisted? ? "Edit Page" : "New Page" %></h1>

<div class="bg-white shadow rounded-lg p-6 max-w-3xl">
  <%= form_with model: [:admin, page], class: "space-y-4" do |f| %>
    <% if page.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-700">
          <% page.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>
    <div>
      <%= f.label :slug, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :slug, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border font-mono", placeholder: "auto-generated" %>
    </div>
    <div>
      <%= f.label :body, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.rich_text_area :body %>
    </div>
    <div>
      <%= f.label :seo_title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :seo_title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>
    <div>
      <%= f.label :meta_description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :meta_description, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>

    <div class="flex items-center gap-4 pt-4">
      <%= f.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
      <%= link_to "Cancel", admin_static_pages_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      <% if page.persisted? %>
        <%= button_to "Delete", admin_static_page_path(page), method: :delete,
            class: "ml-auto text-sm text-red-600 hover:text-red-800 cursor-pointer",
            data: { turbo_confirm: "Are you sure?" } %>
      <% end %>
    </div>
  <% end %>
</div>
