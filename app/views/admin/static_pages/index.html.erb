<% content_for :title, "Static Pages" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Static Pages</h1>
  <%= link_to "New Page", new_admin_static_page_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Slug</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Updated</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @pages.each do |page| %>
        <tr>
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= page.title %></td>
          <td class="px-6 py-4 text-sm text-gray-500 font-mono"><%= page.slug %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= page.updated_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-4 text-right text-sm">
            <%= link_to "Edit", edit_admin_static_page_path(page), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
