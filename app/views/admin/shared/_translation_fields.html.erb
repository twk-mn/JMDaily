<%#
  Per-locale translation input sections for any model that includes
  Translatable. Renders one card per active non-English SiteLanguage,
  with one input per translatable attribute.

  Required locals:
    f      — the parent record's form builder
    record — the parent record (Location, Category, Tag, Author, StaticPage)
    attrs  — Array of [attr, kind] pairs. Supported kinds:
             :string     → text_field
             :text       → text_area (rows: 3)
             :rich_text  → rich_text_area (Trix editor; for ActionText fields)
             e.g. [[:title, :string], [:body, :rich_text]]

  An editor leaving every input blank in a section drops that
  translation row at save time (Translatable#translation_attrs_blank?),
  so admins can ignore languages they aren't translating yet.
%>
<% other_translations = record.translations.reject { |t| t.locale == "en" }.sort_by(&:locale) %>
<% if other_translations.any? %>
  <div class="space-y-6 pt-4 border-t border-gray-200">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Translations</h2>
    <p class="text-xs text-gray-500 -mt-2">Leave a section blank to use the English values for that language.</p>

    <% other_translations.each do |translation| %>
      <% lang = SiteLanguage.iso_option(translation.locale) %>
      <%= f.fields_for :translations, translation do |tf| %>
        <%= tf.hidden_field :locale %>
        <div class="rounded-md border border-gray-200 p-4 space-y-3">
          <h3 class="text-sm font-semibold text-gray-700">
            <%= "#{lang[:flag_emoji]} #{lang[:native_name]}" if lang %>
            <span class="text-xs text-gray-500">(<%= translation.locale.upcase %>)</span>
          </h3>
          <% attrs.each do |attr, kind| %>
            <div>
              <%= tf.label attr, class: "block text-sm font-medium text-gray-700" %>
              <% case kind %>
              <% when :rich_text %>
                <%= tf.rich_text_area attr, class: "mt-1 min-h-[200px]" %>
              <% when :text %>
                <%= tf.text_area attr, rows: 3,
                    class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border",
                    placeholder: record.public_send(attr) %>
              <% else %>
                <%= tf.text_field attr,
                    class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border",
                    placeholder: record.public_send(attr) %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
