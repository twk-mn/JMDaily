<% color_classes = {
  "indigo" => "bg-indigo-50 text-indigo-700 border-indigo-200",
  "yellow" => "bg-yellow-50 text-yellow-700 border-yellow-200",
  "blue"   => "bg-blue-50 text-blue-700 border-blue-200",
  "green"  => "bg-green-50 text-green-700 border-green-200"
} %>
<%= link_to href, class: "block bg-white shadow rounded-lg p-5 hover:shadow-md transition-shadow" do %>
  <p class="text-sm font-medium text-gray-500 truncate"><%= label %></p>
  <p class="mt-2 text-3xl font-bold text-gray-900"><%= value %></p>
  <span class="mt-2 inline-block text-xs font-medium px-2 py-0.5 rounded-full border <%= color_classes[color] %>">
    <%= label %>
  </span>
<% end %>
