<% content_for :title, "Dashboard" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
  <p class="mt-1 text-sm text-gray-500"><%= Time.current.strftime("%A, %B %-d, %Y") %></p>
</div>

<!-- Stat cards -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <%= render "stat_card",
      label: "Published",
      value: @article_counts["published"] || 0,
      href: admin_articles_path(status: "published"),
      color: "indigo" %>

  <%= render "stat_card",
      label: "Drafts",
      value: @article_counts["draft"] || 0,
      href: admin_articles_path(status: "draft"),
      color: "yellow" %>

  <%= render "stat_card",
      label: "Scheduled",
      value: @scheduled_count,
      href: admin_articles_path(status: "scheduled"),
      color: "blue" %>

  <%= render "stat_card",
      label: "Subscribers",
      value: @subscriber_count,
      href: admin_newsletter_subscribers_path,
      color: "green" %>
</div>

<!-- Inbox alerts -->
<% if @unread_contacts > 0 || @unread_tips > 0 || @pending_comments > 0 %>
  <div class="mb-8 flex flex-wrap gap-4">
    <% if @unread_contacts > 0 %>
      <%= link_to admin_contact_submissions_path,
          class: "flex items-center gap-3 bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-3 hover:bg-indigo-100 transition-colors" do %>
        <span class="inline-flex items-center justify-center rounded-full bg-indigo-500 text-white text-sm font-bold w-7 h-7"><%= @unread_contacts %></span>
        <span class="text-sm font-medium text-indigo-800">unread <%= "message".pluralize(@unread_contacts) %></span>
      <% end %>
    <% end %>
    <% if @unread_tips > 0 %>
      <%= link_to admin_tip_submissions_path,
          class: "flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 hover:bg-amber-100 transition-colors" do %>
        <span class="inline-flex items-center justify-center rounded-full bg-amber-500 text-white text-sm font-bold w-7 h-7"><%= @unread_tips %></span>
        <span class="text-sm font-medium text-amber-800">unread <%= "tip".pluralize(@unread_tips) %></span>
      <% end %>
    <% end %>
    <% if @pending_comments > 0 %>
      <%= link_to admin_comments_path(status: "pending"),
          class: "flex items-center gap-3 bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-3 hover:bg-yellow-100 transition-colors" do %>
        <span class="inline-flex items-center justify-center rounded-full bg-yellow-500 text-white text-sm font-bold w-7 h-7"><%= @pending_comments %></span>
        <span class="text-sm font-medium text-yellow-800"><%= "comment".pluralize(@pending_comments) %> awaiting moderation</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

  <!-- Left: drafts + published -->
  <div class="lg:col-span-2 space-y-8">

    <!-- Recent drafts -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Recent Drafts</h2>
        <%= link_to "View all", admin_articles_path(status: "draft"), class: "text-xs text-indigo-600 hover:text-indigo-500" %>
      </div>
      <% if @recent_drafts.any? %>
        <ul class="divide-y divide-gray-100">
          <% @recent_drafts.each do |article| %>
            <li class="px-6 py-3 flex items-center justify-between gap-4">
              <div class="min-w-0">
                <%= link_to article.title, edit_admin_article_path(article),
                    class: "text-sm font-medium text-gray-900 hover:text-indigo-600 truncate block" %>
                <p class="text-xs text-gray-400 mt-0.5">
                  <%= article.author.name %> · updated <%= time_ago_in_words(article.updated_at) %> ago
                </p>
              </div>
              <%= link_to "Edit", edit_admin_article_path(article),
                  class: "flex-shrink-0 text-xs text-indigo-600 hover:text-indigo-500" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-6 py-4 text-sm text-gray-400">No drafts.</p>
      <% end %>
    </div>

    <!-- Recently published -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Recently Published</h2>
        <%= link_to "View all", admin_articles_path(status: "published"), class: "text-xs text-indigo-600 hover:text-indigo-500" %>
      </div>
      <% if @recently_published.any? %>
        <ul class="divide-y divide-gray-100">
          <% @recently_published.each do |article| %>
            <li class="px-6 py-3 flex items-center justify-between gap-4">
              <div class="min-w-0">
                <%= link_to article.title, article_path(article), target: "_blank",
                    class: "text-sm font-medium text-gray-900 hover:text-indigo-600 truncate block" %>
                <p class="text-xs text-gray-400 mt-0.5">
                  <%= article.category.name %> · <%= article.published_at.strftime("%b %-d at %-I:%M %p") %>
                </p>
              </div>
              <%= link_to "Edit", edit_admin_article_path(article),
                  class: "flex-shrink-0 text-xs text-indigo-600 hover:text-indigo-500" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-6 py-4 text-sm text-gray-400">No published articles yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Right: quick actions + activity -->
  <div class="space-y-8">

    <!-- Quick actions -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Quick Actions</h2>
      <div class="space-y-2">
        <%= link_to new_admin_article_path,
            class: "block w-full text-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" do %>
          + New Article
        <% end %>
        <%= link_to admin_articles_path(status: "scheduled"),
            class: "block w-full text-center rounded-md bg-white border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" do %>
          <% if @scheduled_count > 0 %>
            <%= @scheduled_count %> scheduled <%= "article".pluralize(@scheduled_count) %>
          <% else %>
            No scheduled articles
          <% end %>
        <% end %>
        <% if @published_today > 0 %>
          <p class="text-center text-xs text-gray-500 pt-1">
            <%= @published_today %> <%= "article".pluralize(@published_today) %> published today
          </p>
        <% end %>
      </div>
    </div>

    <!-- Newsletter snapshot -->
    <div class="bg-white shadow rounded-lg p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Newsletter</h2>
        <%= link_to "Manage", admin_newsletter_subscribers_path, class: "text-xs text-indigo-600 hover:text-indigo-500" %>
      </div>
      <dl class="space-y-2">
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">Active subscribers</dt>
          <dd class="font-semibold text-gray-900"><%= @subscriber_count %></dd>
        </div>
        <div class="flex justify-between text-sm">
          <dt class="text-gray-500">New this week</dt>
          <dd class="font-semibold text-<%= @new_subscribers_this_week > 0 ? "green" : "gray" %>-600">
            +<%= @new_subscribers_this_week %>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Recent activity -->
    <div class="bg-white shadow rounded-lg">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Recent Activity</h2>
        <%= link_to "Full log", admin_audit_logs_path, class: "text-xs text-indigo-600 hover:text-indigo-500" %>
      </div>
      <% if @recent_audit_logs.any? %>
        <ul class="divide-y divide-gray-100">
          <% @recent_audit_logs.each do |log| %>
            <li class="px-6 py-2.5">
              <p class="text-xs text-gray-700">
                <span class="font-medium"><%= log.user&.name || "System" %></span>
                <%= log.action %>d
                <span class="text-gray-500"><%= log.resource_label %></span>
              </p>
              <p class="text-xs text-gray-400"><%= time_ago_in_words(log.created_at) %> ago</p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-6 py-4 text-sm text-gray-400">No activity yet.</p>
      <% end %>
    </div>

  </div>
</div>
