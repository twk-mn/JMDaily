<% content_for :title, "Newsletter Subscribers" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Newsletter Subscribers</h1>
  <%= link_to "Export CSV", admin_newsletter_subscribers_path(format: :csv),
      class: "rounded-md bg-white border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
  <div class="bg-white shadow rounded-lg p-4">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Active</p>
    <p class="mt-1 text-2xl font-bold text-gray-900"><%= @active_count %></p>
  </div>
  <div class="bg-white shadow rounded-lg p-4">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">New this week</p>
    <p class="mt-1 text-2xl font-bold text-<%= @new_this_week > 0 ? "green" : "gray" %>-600">+<%= @new_this_week %></p>
  </div>
  <div class="bg-white shadow rounded-lg p-4">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">New this month</p>
    <p class="mt-1 text-2xl font-bold text-gray-900">+<%= @new_this_month %></p>
  </div>
  <div class="bg-white shadow rounded-lg p-4">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Unsubscribed</p>
    <p class="mt-1 text-2xl font-bold text-gray-400"><%= @unsubscribed_count %></p>
  </div>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Signed up</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Confirmed</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @subscribers.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-400">No subscribers yet.</td>
        </tr>
      <% end %>
      <% @subscribers.each do |sub| %>
        <tr class="bg-white hover:bg-gray-50">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= sub.email %></td>
          <td class="px-6 py-4 text-sm">
            <% if sub.unsubscribed? %>
              <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600">Unsubscribed</span>
            <% elsif sub.confirmed? %>
              <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">Active</span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-700">Pending</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">
            <%= sub.created_at.strftime("%-d %b %Y") %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">
            <%= sub.confirmed_at ? sub.confirmed_at.strftime("%-d %b %Y") : "—" %>
          </td>
          <td class="px-6 py-4 text-right text-sm">
            <%= button_to "Remove", admin_newsletter_subscriber_path(sub), method: :delete,
                class: "text-red-600 hover:text-red-800 cursor-pointer",
                data: { turbo_confirm: "Remove #{sub.email} from the list?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy && @pagy.pages > 1 %>
  <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
    <span><%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %></span>
    <nav class="flex gap-1">
      <% if @pagy.prev %>
        <%= link_to "← Previous", admin_newsletter_subscribers_path(page: @pagy.prev), class: "px-3 py-1.5 rounded border border-gray-300 bg-white hover:bg-gray-50" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Next →", admin_newsletter_subscribers_path(page: @pagy.next), class: "px-3 py-1.5 rounded border border-gray-300 bg-white hover:bg-gray-50" %>
      <% end %>
    </nav>
  </div>
<% end %>
