<div class="bg-white shadow rounded-lg p-6">
  <%= form_with url: admin_settings_path, method: :patch, local: true, class: "space-y-6" do %>
    <% @definitions.each do |key, defn| %>
      <div>
        <label for="settings_<%= key %>" class="block text-sm font-medium text-gray-700">
          <%= defn[:label] %>
        </label>
        <% case defn[:type] %>
        <% when "boolean" %>
          <div class="mt-2 flex items-center gap-2">
            <input type="hidden" name="settings[<%= key %>]" value="0">
            <input type="checkbox" id="settings_<%= key %>" name="settings[<%= key %>]" value="1"
                   <%= "checked" if @values[key] %>
                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
          </div>
        <% when "text" %>
          <textarea id="settings_<%= key %>" name="settings[<%= key %>]" rows="4"
                    class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"><%= @values[key] %></textarea>
        <% else %>
          <% input_type = defn[:input_type] || (defn[:type] == "integer" ? "number" : "text") %>
          <% if input_type == "select" %>
            <select id="settings_<%= key %>" name="settings[<%= key %>]"
                    class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
              <% Array(defn[:options]).each do |label, value| %>
                <option value="<%= value %>" <%= "selected" if @values[key].to_s == value.to_s %>><%= label %></option>
              <% end %>
            </select>
          <% else %>
            <input type="<%= input_type %>"
                   id="settings_<%= key %>" name="settings[<%= key %>]"
                   value="<%= @values[key] %>"
                   <%= 'autocomplete="off"'.html_safe if input_type == "password" %>
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
          <% end %>
        <% end %>
        <% if defn[:description].present? %>
          <p class="mt-1 text-sm text-gray-500"><%= defn[:description] %></p>
        <% end %>
      </div>
    <% end %>

    <div class="pt-4 border-t border-gray-200 flex justify-end">
      <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
        Save changes
      </button>
    </div>
  <% end %>
</div>
