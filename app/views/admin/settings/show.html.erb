<% content_for :title, "Settings" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6">Settings</h1>

<div class="border-b border-gray-200 mb-6">
  <nav class="-mb-px flex space-x-8" aria-label="Tabs">
    <% Admin::SettingsController::TABS.each do |tab| %>
      <% active = (tab == @tab) %>
      <%= link_to tab.titleize,
                  admin_settings_tab_path(tab: tab),
                  class: "whitespace-nowrap border-b-2 py-3 px-1 text-sm font-medium " +
                         (active ? "border-indigo-500 text-indigo-600" : "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700") %>
    <% end %>
  </nav>
</div>

<% if @tab == "languages" %>
  <%= render "languages_tab" %>
<% else %>
  <%= render "general_tab" %>
<% end %>
