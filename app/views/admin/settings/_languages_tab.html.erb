<div class="space-y-6">
  <div class="bg-white shadow rounded-lg overflow-hidden"
       data-controller="site-languages">
    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">Site languages</h2>
      <p class="text-sm text-gray-500">Deactivated languages are hidden from the public site but their content is retained until you purge.</p>
    </div>

    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Language</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Code</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Content</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @site_languages.each do |lang| %>
          <% counts = lang.content_counts %>
          <tr>
            <td class="px-6 py-4 text-sm text-gray-900">
              <span class="text-xl mr-2"><%= lang.flag_emoji %></span>
              <span class="font-medium"><%= lang.name %></span>
              <span class="text-gray-500 ml-2"><%= lang.native_name %></span>
              <% unless lang.deletable %>
                <span class="ml-2 inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">Required</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm font-mono text-gray-500"><%= lang.code %></td>
            <td class="px-6 py-4 text-sm">
              <% if lang.active %>
                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Active</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">Hidden</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= counts[:articles] %> articles,
              <%= counts[:newsletter_issues] %> newsletters
            </td>
            <td class="px-6 py-4 text-right text-sm space-x-3 whitespace-nowrap">
              <% if lang.active && lang.deactivatable? %>
                <%= button_to "Deactivate",
                              deactivate_admin_site_language_path(lang),
                              method: :post,
                              class: "text-indigo-600 hover:text-indigo-900 bg-transparent border-0 p-0 cursor-pointer",
                              form: { class: "inline" } %>
              <% elsif !lang.active && lang.deletable %>
                <%= button_to "Activate",
                              activate_admin_site_language_path(lang),
                              method: :post,
                              class: "text-green-600 hover:text-green-900 bg-transparent border-0 p-0 cursor-pointer",
                              form: { class: "inline" } %>
              <% end %>

              <% if lang.purgeable? %>
                <button type="button"
                        data-action="site-languages#openPurge"
                        data-code="<%= lang.code %>"
                        data-name="<%= lang.name %>"
                        data-articles="<%= counts[:articles] %>"
                        data-newsletters="<%= counts[:newsletter_issues] %>"
                        data-purge-url="<%= admin_site_language_path(lang) %>"
                        class="text-red-600 hover:text-red-900">
                  Total delete
                </button>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%= render "purge_modal" %>
  </div>

  <% if @addable_iso_options.any? %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Add a language</h2>
      <%= form_with url: admin_site_languages_path, method: :post, local: true, class: "flex gap-3 items-end" do %>
        <div class="flex-1">
          <label for="site_language_code" class="block text-sm font-medium text-gray-700">Language</label>
          <select id="site_language_code" name="site_language[code]" required
                  class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            <% @addable_iso_options.each do |opt| %>
              <option value="<%= opt[:code] %>"><%= opt[:flag_emoji] %> <%= opt[:name] %> (<%= opt[:native_name] %>)</option>
            <% end %>
          </select>
        </div>
        <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
          Add language
        </button>
      <% end %>
      <p class="mt-2 text-sm text-gray-500">New languages start active. You can hide one later without losing its content.</p>
    </div>
  <% end %>
</div>
