<% content_for :title, author.persisted? ? "Edit Author" : "New Author" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6"><%= author.persisted? ? "Edit Author" : "New Author" %></h1>

<div class="bg-white shadow rounded-lg p-6 max-w-lg">
  <%= form_with model: [:admin, author], class: "space-y-4" do |f| %>
    <% if author.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-700">
          <% author.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>
    <div>
      <%= f.label :slug, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :slug, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border font-mono", placeholder: "auto-generated" %>
    </div>
    <div>
      <%= f.label :role_title, "Role / Title", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :role_title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border", placeholder: "e.g. Editor, Reporter" %>
    </div>
    <div>
      <%= f.label :bio, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :bio, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>
    <div>
      <%= f.label :photo, class: "block text-sm font-medium text-gray-700" %>
      <% if author.photo.attached? %>
        <div class="mb-2">
          <%= image_tag author.photo.variant(resize_to_limit: [100, 100]), class: "rounded-full w-16 h-16 object-cover" %>
        </div>
      <% end %>
      <%= f.file_field :photo, accept: "image/*",
          class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
    </div>
    <div>
      <%= f.label :twitter_url, "Twitter URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.url_field :twitter_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>
    <div>
      <%= f.label :website_url, "Website URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.url_field :website_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
    </div>

    <div class="flex items-center gap-4 pt-4">
      <%= f.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
      <%= link_to "Cancel", admin_authors_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      <% if author.persisted? %>
        <%= button_to "Delete", admin_author_path(author), method: :delete,
            class: "ml-auto text-sm text-red-600 hover:text-red-800 cursor-pointer",
            data: { turbo_confirm: "Are you sure?" } %>
      <% end %>
    </div>
  <% end %>
</div>
