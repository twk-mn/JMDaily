<% content_for :title, "Two-Factor Authentication" %>

<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-1">Two-Factor Authentication</h1>
  <p class="text-sm text-gray-500 mb-8">Add an extra layer of security to your account using a TOTP authenticator app (Google Authenticator, Authy, 1Password, etc).</p>

  <% if current_user.otp_enabled? %>
    <div class="rounded-md bg-green-50 border border-green-200 p-4 mb-8 flex items-center gap-3">
      <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div>
        <p class="text-sm font-medium text-green-800">Two-factor authentication is enabled</p>
        <p class="text-xs text-green-700 mt-0.5">Enabled <%= current_user.totp_enabled_at.strftime("%-d %b %Y") %></p>
      </div>
    </div>

    <%= button_to "Disable two-factor authentication", admin_two_factor_disable_path, method: :delete,
        class: "rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500 cursor-pointer",
        data: { turbo_confirm: "Are you sure? This will remove 2FA from your account." } %>

  <% else %>
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Set up authenticator app</h2>

      <ol class="space-y-4 text-sm text-gray-700 mb-6">
        <li><span class="font-medium">1.</span> Open your authenticator app and choose "Add account" or scan a QR code.</li>
        <li><span class="font-medium">2.</span> Scan the QR code below, or enter the secret key manually.</li>
        <li><span class="font-medium">3.</span> Enter the 6-digit code shown in the app to confirm setup.</li>
      </ol>

      <div class="flex justify-center mb-4">
        <div class="inline-block border border-gray-200 rounded p-2 bg-white">
          <%= raw @qr_svg %>
        </div>
      </div>

      <div class="text-center mb-6">
        <p class="text-xs text-gray-500 mb-1">Manual entry key</p>
        <code class="text-sm font-mono bg-gray-100 px-3 py-1.5 rounded tracking-widest select-all"><%= current_user.totp_secret&.scan(/.{4}/)&.join(" ") %></code>
      </div>

      <%= form_with url: admin_two_factor_enable_path, method: :post, class: "space-y-4 max-w-xs mx-auto" do |f| %>
        <div>
          <%= f.label :otp_code, "Verification code", class: "block text-sm font-medium text-gray-700 text-center" %>
          <div class="mt-1">
            <%= f.text_field :otp_code,
                required: true, autofocus: true,
                autocomplete: "one-time-code",
                inputmode: "numeric", pattern: "[0-9 ]*",
                maxlength: 7,
                placeholder: "000000",
                class: "block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500 text-center text-lg tracking-widest" %>
          </div>
        </div>
        <div>
          <%= f.submit "Enable two-factor authentication",
              class: "w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
