<% content_for :title, tag.persisted? ? "Edit Tag" : "New Tag" %>

<h1 class="text-2xl font-bold text-gray-900 mb-6"><%= tag.persisted? ? "Edit Tag" : "New Tag" %></h1>

<div class="bg-white shadow rounded-lg p-6 max-w-lg">
  <%= form_with model: [:admin, tag], class: "space-y-4" do |f| %>
    <% if tag.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-700">
          <% tag.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-4">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">English (default)</h2>
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border" %>
      </div>
      <div>
        <%= f.label :slug, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :slug, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm text-sm px-3 py-2 border font-mono", placeholder: "auto-generated" %>
        <p class="mt-1 text-xs text-gray-500">URL slug — stays English across all languages.</p>
      </div>
    </div>

    <%= render "admin/shared/translation_fields",
        f: f,
        record: tag,
        attrs: [ [ :name, :string ] ] %>

    <div class="flex items-center gap-4 pt-4">
      <%= f.submit class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
      <%= link_to "Cancel", admin_tags_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      <% if tag.persisted? %>
        <%= button_to "Delete", admin_tag_path(tag), method: :delete,
            class: "ml-auto text-sm text-red-600 hover:text-red-800 cursor-pointer",
            data: { turbo_confirm: "Are you sure?" } %>
      <% end %>
    </div>
  <% end %>
</div>
