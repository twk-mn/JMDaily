<% content_for :title, "Ads" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Ads</h1>
  <%= link_to "New Ad", new_admin_ad_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Zone</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Flight</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Impr.</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Clicks</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if @ads.empty? %>
        <tr>
          <td colspan="8" class="px-6 py-10 text-center text-sm text-gray-400">
            No ads yet. <%= link_to "Create one", new_admin_ad_path, class: "text-indigo-600 hover:underline" %>.
          </td>
        </tr>
      <% end %>
      <% @ads.each do |ad| %>
        <tr class="<%= ad.running? ? '' : 'opacity-50' %>">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= ad.name %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= ad.zone_label %></td>
          <td class="px-6 py-4 text-sm text-gray-500 capitalize"><%= ad.ad_type.humanize %></td>
          <td class="px-6 py-4 text-sm">
            <% badge_class = case ad.status
               when "active" then "bg-green-100 text-green-800"
               when "paused" then "bg-yellow-100 text-yellow-800"
               else "bg-gray-100 text-gray-600"
               end %>
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= badge_class %>">
              <%= ad.status.capitalize %>
            </span>
          </td>
          <td class="px-6 py-4 text-xs text-gray-500">
            <% if ad.starts_at || ad.ends_at %>
              <%= ad.starts_at&.strftime("%-d %b %Y") || "—" %> →
              <%= ad.ends_at&.strftime("%-d %b %Y") || "ongoing" %>
            <% else %>
              Always
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= number_with_delimiter(ad.impressions_count) %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= number_with_delimiter(ad.clicks_count) %></td>
          <td class="px-6 py-4 text-right text-sm">
            <%= link_to "Edit", edit_admin_ad_path(ad), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
