<% content_for :title, "Categories" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Categories</h1>
  <%= link_to "New Category", new_admin_category_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Position</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Slug</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Articles</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @categories.each do |category| %>
        <tr>
          <td class="px-6 py-4 text-sm text-gray-500"><%= category.position %></td>
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= category.name %></td>
          <td class="px-6 py-4 text-sm text-gray-500 font-mono"><%= category.slug %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= category.articles.count %></td>
          <td class="px-6 py-4 text-right text-sm">
            <%= link_to "Edit", edit_admin_category_path(category), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy && @pagy.pages > 1 %>
  <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
    <span><%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %> categories</span>
    <nav class="flex gap-1">
      <% if @pagy.prev %>
        <%= link_to "← Previous", admin_categories_path(page: @pagy.prev),
            class: "px-3 py-1.5 rounded border border-gray-300 bg-white hover:bg-gray-50" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Next →", admin_categories_path(page: @pagy.next),
            class: "px-3 py-1.5 rounded border border-gray-300 bg-white hover:bg-gray-50" %>
      <% end %>
    </nav>
  </div>
<% end %>
