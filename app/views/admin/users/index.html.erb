<% content_for :title, "Users" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Users</h1>
  <%= link_to "New User", new_admin_user_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Author profile</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @users.each do |user| %>
        <tr>
          <td class="px-6 py-4 text-sm font-medium text-gray-900">
            <%= user.name %>
            <% if user == current_user %>
              <span class="ml-1 text-xs text-gray-400">(you)</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 font-mono"><%= user.email %></td>
          <td class="px-6 py-4 text-sm">
            <% badge = user.admin? ? "bg-purple-100 text-purple-800" : "bg-gray-100 text-gray-700" %>
            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= badge %>">
              <%= user.role.capitalize %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500">
            <% if user.author %>
              <%= link_to user.author.name, edit_admin_author_path(user.author), class: "text-indigo-600 hover:underline" %>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-right text-sm">
            <%= link_to "Edit", edit_admin_user_path(user), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
