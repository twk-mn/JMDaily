<% content_for :title, @state == :invalid ? "Unsubscribe link" : "You're unsubscribed" %>

<div class="mx-auto max-w-md px-4 sm:px-6 lg:px-8 py-16">
  <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl px-6 py-8 sm:px-8 sm:py-10 text-center">
    <% case @state %>
    <% when :unsubscribed %>
      <svg class="mx-auto w-12 h-12 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
      <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif">You're unsubscribed</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        We've removed <span class="font-medium"><%= @subscriber.email %></span> from the Joetsu-Myoko Daily list. You won't receive any more emails from us.
      </p>
      <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Changed your mind? You can resubscribe any time.</p>
      <div class="mt-6 text-left">
        <%= turbo_frame_tag "newsletter-signup-resubscribe" do %>
          <%= render "newsletter_subscriptions/signup_form",
              frame_id: "newsletter-signup-resubscribe",
              input_id: "resubscribe-newsletter-email",
              layout: :stacked,
              submit_label: "Resubscribe" %>
        <% end %>
      </div>
    <% when :already_unsubscribed %>
      <svg class="mx-auto w-12 h-12 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif">Already unsubscribed</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        <span class="font-medium"><%= @subscriber.email %></span> isn't on our list — you're all set.
      </p>
      <%= link_to "Back to the homepage", locale_root_path,
          class: "mt-6 inline-flex items-center justify-center min-h-[44px] rounded-md bg-indigo-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
    <% else %>
      <svg class="mx-auto w-12 h-12 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif">We couldn't find that subscription</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        The unsubscribe link is invalid or the email isn't on our list. If you're getting unwanted emails, reply to one of them and we'll remove you manually.
      </p>
      <%= link_to "Back to the homepage", locale_root_path,
          class: "mt-6 inline-flex items-center justify-center min-h-[44px] rounded-md bg-indigo-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
    <% end %>
  </div>
</div>
