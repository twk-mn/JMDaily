<%# Bare newsletter signup form (no turbo-frame wrapper). The caller is
    responsible for wrapping in a turbo_frame_tag of the same id passed
    here so the response can replace it inline.

    Locals:
      frame_id: required — id of the turbo-frame the response targets
      input_id: required — unique id for the email input (so the label
        targets the correct input when both home + footer forms render
        on the same page)
      layout:   :stacked or :inline (default)
      submit_label: optional — defaults to "Subscribe" %>

<% frame_id    = local_assigns.fetch(:frame_id) %>
<% input_id    = local_assigns.fetch(:input_id) %>
<% layout      = local_assigns.fetch(:layout, :inline) %>
<% submit_label = local_assigns.fetch(:submit_label, "Subscribe") %>
<% form_class  = layout == :stacked ? "space-y-2" : "flex flex-col sm:flex-row gap-2 sm:gap-3" %>
<% input_class = "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 focus:border-indigo-500 focus:ring-indigo-500" %>
<% button_class = "inline-flex items-center justify-center min-h-[44px] rounded-md bg-indigo-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" %>

<%= form_with url: newsletter_subscribe_path, method: :post,
    data: { turbo_frame: frame_id } do |f| %>
  <%= hidden_field_tag :frame_id, frame_id %>
  <%= hidden_field_tag :input_id, input_id %>
  <div class="<%= form_class %>">
    <label for="<%= input_id %>" class="sr-only">Email address</label>
    <%= f.email_field :email, required: true,
        id: input_id,
        placeholder: "you@example.com",
        autocomplete: "email",
        class: layout == :stacked ? input_class : "#{input_class} flex-1 min-w-0" %>
    <%= f.submit submit_label,
        class: layout == :stacked ? "#{button_class} w-full" : "#{button_class} shrink-0" %>
  </div>
  <%= render "shared/turnstile_widget", form_key: "newsletter" %>
<% end %>
