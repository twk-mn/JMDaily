<%# Frame replacement shown after a successful subscribe.
    Locals:
      frame_id: required
      email: optional — the email that was subscribed %>
<% frame_id = local_assigns.fetch(:frame_id) %>
<% email = local_assigns[:email] %>

<%= turbo_frame_tag frame_id do %>
  <div role="status" aria-live="polite"
       class="rounded-md border border-green-200 dark:border-green-900 bg-green-50 dark:bg-green-950/30 px-4 py-3">
    <p class="text-sm font-semibold text-green-800 dark:text-green-200">Almost there — check your inbox.</p>
    <p class="mt-1 text-xs text-green-700 dark:text-green-300">
      We sent a confirmation link<% if email.present? %> to <span class="font-medium"><%= email %></span><% end %>. Click it to finish subscribing.
    </p>
  </div>
<% end %>
