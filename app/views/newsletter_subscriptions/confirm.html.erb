<% content_for :title, @state == :confirmed ? "You're subscribed" : "Confirmation link" %>

<div class="mx-auto max-w-md px-4 sm:px-6 lg:px-8 py-16">
  <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl px-6 py-8 sm:px-8 sm:py-10 text-center">
    <% case @state %>
    <% when :confirmed %>
      <svg class="mx-auto w-12 h-12 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif">You're subscribed</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        Thanks for confirming. We'll send the next Joetsu-Myoko Daily roundup straight to <span class="font-medium"><%= @subscriber.email %></span>.
      </p>
      <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
        Want to change your mind later? Every email has a one-click unsubscribe link.
      </p>
      <%= link_to "Back to the homepage", locale_root_path,
          class: "mt-6 inline-flex items-center justify-center min-h-[44px] rounded-md bg-indigo-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
    <% else %>
      <svg class="mx-auto w-12 h-12 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif">This link has expired</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
        The confirmation link is invalid or has already been used. If you've already confirmed, you're all set — no further action needed.
      </p>
      <p class="mt-4 text-sm text-gray-700 dark:text-gray-300">Need to start over? Sign up again below.</p>
      <div class="mt-6 text-left">
        <%= turbo_frame_tag "newsletter-signup-confirm" do %>
          <%= render "newsletter_subscriptions/signup_form",
              frame_id: "newsletter-signup-confirm",
              input_id: "confirm-newsletter-email",
              layout: :stacked %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
