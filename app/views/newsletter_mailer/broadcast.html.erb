<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body { font-family: Georgia, serif; color: #111827; background: #f9fafb; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 0 auto; background: #ffffff; }
    .header { background: #1f2937; padding: 24px 32px; }
    .header a { color: #ffffff; font-family: Georgia, serif; font-size: 22px; font-weight: bold; text-decoration: none; }
    .content { padding: 32px; }
    .content p { line-height: 1.7; margin: 0 0 16px; font-size: 16px; }
    .footer { background: #f3f4f6; padding: 20px 32px; border-top: 1px solid #e5e7eb; }
    .footer p { font-family: sans-serif; font-size: 12px; color: #6b7280; margin: 0 0 4px; }
    .footer a { color: #4f46e5; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <a href="<%= @home_url %>">Joetsu-Myoko Daily</a>
    </div>
    <div class="content">
      <%= simple_format(@issue.body) %>
    </div>
    <div class="footer">
      <p>You're receiving this because you subscribed to the Joetsu-Myoko Daily newsletter.</p>
      <p><a href="<%= @unsubscribe_url %>">Unsubscribe</a></p>
    </div>
  </div>
</body>
</html>
