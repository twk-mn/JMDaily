<%# Mobile language switcher — full native names rendered as pills. %>
<% options = language_switcher_options %>
<% if options.size > 1 %>
  <div class="border-t border-gray-100 dark:border-gray-800 pt-2 mt-2 flex flex-wrap gap-2 px-3" role="group" aria-label="Language">
    <% options.each do |opt| %>
      <%= link_to opt[:url],
          class: "text-sm px-3 py-1 rounded border #{opt[:current] ? 'bg-indigo-600 text-white border-indigo-600' : 'border-gray-300 dark:border-gray-700 text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-900'} focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600",
          lang: opt[:code],
          "aria-current": (opt[:current] ? "true" : nil) do %>
        <%= opt[:display_name] %>
      <% end %>
    <% end %>
  </div>
<% end %>
