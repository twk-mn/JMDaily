<header class="border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
  <!-- Masthead -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6 text-center">
    <%= link_to root_path, class: "inline-block focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-indigo-600 rounded" do %>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-100 font-serif">
        Joetsu-Myoko Daily
      </h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Local news in English — Joetsu · Myoko · Niigata</p>
    <% end %>
  </div>

  <!-- Header banner ad -->
  <% header_ad = ad_for("header_banner") %>
  <% if header_ad %>
    <div class="border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex justify-center">
        <%= header_ad %>
      </div>
    </div>
  <% end %>

  <!-- Navigation -->
  <nav class="border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-950" data-controller="mobile-menu" aria-label="Primary">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-12">
        <div class="hidden md:flex items-center space-x-1">
          <%= link_to "News", news_path, class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Politics", politics_path, class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Business", business_path, class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Community", community_path, class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Weather & Travel", weather_travel_path, class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Events", events_path, class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <span class="text-gray-300 dark:text-gray-700 px-1" aria-hidden="true">|</span>
          <%= link_to "Joetsu", location_path("joetsu"), class: "px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Myoko", location_path("myoko"), class: "px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Itoigawa", location_path("itoigawa"), class: "px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        </div>

        <div class="hidden md:flex items-center gap-3">
          <!-- Language switcher -->
          <div class="flex items-center gap-1 text-sm border border-gray-200 dark:border-gray-700 rounded-md overflow-hidden" role="group" aria-label="Language">
            <%= link_to "EN", root_path(locale: "en"),
                class: "px-2 py-1 #{I18n.locale.to_s == 'en' ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900'}" %>
            <%= link_to "JP", root_path(locale: "ja"),
                class: "px-2 py-1 #{I18n.locale.to_s == 'ja' ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900'}" %>
          </div>

          <!-- Dark mode toggle -->
          <%= render "shared/theme_toggle" %>

          <%= form_with url: search_path, method: :get, class: "flex items-center" do %>
            <label for="site-search" class="sr-only">Search</label>
            <input type="search" id="site-search" name="q" placeholder="Search..." value="<%= params[:q] %>"
                   class="block w-40 rounded-md border-0 py-1 px-3 text-sm text-gray-900 dark:text-gray-100 bg-white dark:bg-gray-900 ring-1 ring-inset ring-gray-300 dark:ring-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-600">
          <% end %>
        </div>

        <!-- Mobile menu button -->
        <div class="md:hidden flex items-center w-full justify-between">
          <button type="button" data-action="click->mobile-menu#toggle"
                  aria-expanded="false" aria-controls="mobile-menu"
                  class="text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-2 py-1 text-sm font-medium">
            ☰ Menu
          </button>
          <div class="flex items-center gap-2">
            <%= render "shared/theme_toggle" %>
            <%= form_with url: search_path, method: :get, class: "flex items-center" do %>
              <label for="site-search-mobile" class="sr-only">Search</label>
              <input type="search" id="site-search-mobile" name="q" placeholder="Search..." value="<%= params[:q] %>"
                     class="block w-32 rounded-md border-0 py-1 px-2 text-sm text-gray-900 dark:text-gray-100 bg-white dark:bg-gray-900 ring-1 ring-inset ring-gray-300 dark:ring-gray-700 placeholder:text-gray-400 focus:ring-2 focus:ring-indigo-600">
            <% end %>
          </div>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="md:hidden hidden pb-4 space-y-1" data-mobile-menu-target="menu">
        <%= link_to "News", news_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        <%= link_to "Politics", politics_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        <%= link_to "Business", business_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        <%= link_to "Community", community_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        <%= link_to "Weather & Travel", weather_travel_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        <%= link_to "Events", events_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        <div class="border-t border-gray-100 dark:border-gray-800 pt-2 mt-2">
          <%= link_to "Joetsu", location_path("joetsu"), class: "block px-3 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Myoko", location_path("myoko"), class: "block px-3 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
          <%= link_to "Itoigawa", location_path("itoigawa"), class: "block px-3 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900 rounded-md" %>
        </div>
        <div class="border-t border-gray-100 dark:border-gray-800 pt-2 mt-2 flex gap-2 px-3">
          <%= link_to "English", root_path(locale: "en"),
              class: "text-sm px-3 py-1 rounded border #{I18n.locale.to_s == 'en' ? 'bg-indigo-600 text-white border-indigo-600' : 'border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300'}" %>
          <%= link_to "日本語", root_path(locale: "ja"),
              class: "text-sm px-3 py-1 rounded border #{I18n.locale.to_s == 'ja' ? 'bg-indigo-600 text-white border-indigo-600' : 'border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300'}" %>
        </div>
      </div>
    </div>
  </nav>
</header>
