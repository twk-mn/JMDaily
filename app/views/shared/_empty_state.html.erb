<%# Empty-state block for index pages with no results.
    Locals:
      heading: required — primary message
      body:    optional — secondary guidance %>
<% heading = local_assigns[:heading] %>
<% body = local_assigns[:body] %>

<div class="text-center py-16 px-4">
  <svg class="mx-auto w-12 h-12 text-gray-400 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
  </svg>
  <p class="mt-4 text-lg font-medium text-gray-900 dark:text-gray-100"><%= heading %></p>
  <% if body.present? %>
    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400"><%= body %></p>
  <% end %>
</div>
