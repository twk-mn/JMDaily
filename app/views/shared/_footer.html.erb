<% footer_ad = ad_for("footer_banner") %>
<% if footer_ad %>
  <div class="border-t border-gray-100 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex justify-center">
      <%= footer_ad %>
    </div>
  </div>
<% end %>

<footer class="bg-gray-50 border-t border-gray-200 mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- About -->
      <div class="md:col-span-2">
        <h3 class="text-lg font-bold text-gray-900" style="font-family: Georgia, serif;">Joetsu-Myoko Daily</h3>
        <p class="mt-2 text-sm text-gray-600 leading-relaxed">
          Independent English-language news covering Joetsu, Myoko, and the surrounding region in Niigata Prefecture, Japan.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">About</h4>
        <ul class="mt-3 space-y-2">
          <li><%= link_to "About Us", about_path, class: "text-sm text-gray-600 hover:text-gray-900" %></li>
          <li><%= link_to "Contact", contact_path, class: "text-sm text-gray-600 hover:text-gray-900" %></li>
          <li><%= link_to "Submit a Tip", submit_a_tip_path, class: "text-sm text-gray-600 hover:text-gray-900" %></li>
          <li><%= link_to "Corrections Policy", corrections_policy_path, class: "text-sm text-gray-600 hover:text-gray-900" %></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Legal</h4>
        <ul class="mt-3 space-y-2">
          <li><%= link_to "Privacy Policy", privacy_policy_path, class: "text-sm text-gray-600 hover:text-gray-900" %></li>
          <li><%= link_to "Terms", terms_path, class: "text-sm text-gray-600 hover:text-gray-900" %></li>
          <li><%= link_to "RSS Feed", feed_path(format: :rss), class: "text-sm text-gray-600 hover:text-gray-900" %></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-400 text-center">
        &copy; <%= Date.current.year %> Joetsu-Myoko Daily. All rights reserved.
      </p>
    </div>
  </div>
</footer>
