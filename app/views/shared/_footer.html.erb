<% footer_ad = ad_for("footer_banner") %>
<% if footer_ad %>
  <div class="border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex justify-center">
      <%= footer_ad %>
    </div>
  </div>
<% end %>

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- About -->
      <div class="md:col-span-1">
        <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 font-serif"><%= Setting.site_name %></h3>
        <% footer_blurb = Setting.site_tagline.presence ||
                          "Independent English-language news covering Joetsu, Myoko, and the surrounding region in Niigata Prefecture, Japan." %>
        <p class="mt-2 text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
          <%= footer_blurb %>
        </p>
      </div>

      <!-- Newsletter signup -->
      <div class="md:col-span-1">
        <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider"><%= t_ui("footer.stay_informed_heading") %></h4>
        <p class="mt-2 text-sm text-gray-700 dark:text-gray-300"><%= t_ui("footer.stay_informed_blurb") %></p>
        <div class="mt-3">
          <% footer_frame_id = "newsletter-signup-footer" %>
          <%= turbo_frame_tag footer_frame_id do %>
            <%= render "newsletter_subscriptions/signup_form",
                frame_id: footer_frame_id,
                input_id: "footer-newsletter-email" %>
          <% end %>
        </div>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider"><%= t_ui("footer.about_heading") %></h4>
        <ul class="mt-3 space-y-2">
          <li><%= link_to t_ui("footer.about_us"), about_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
          <li><%= link_to t_ui("footer.contact"), contact_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
          <li><%= link_to t_ui("footer.submit_a_tip"), submit_a_tip_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
          <li><%= link_to t_ui("footer.corrections_policy"), corrections_policy_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900 dark:text-gray-100 uppercase tracking-wider"><%= t_ui("footer.legal_heading") %></h4>
        <ul class="mt-3 space-y-2">
          <li><%= link_to t_ui("footer.privacy_policy"), privacy_policy_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
          <li><%= link_to t_ui("footer.terms"), terms_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
          <li><%= link_to t_ui("footer.rss_feed"), feed_path(format: :rss), class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800">
      <p class="text-sm text-gray-600 dark:text-gray-400 text-center">
        &copy; <%= Date.current.year %> <%= Setting.site_name %>. <%= t_ui("footer.copyright_suffix") %>
      </p>
    </div>
  </div>
</footer>
