<%# Compact card used in related-stories and more-from-author grids. %>
<% t = article.translation_for(I18n.locale) || article.translations.first %>
<% if t %>
  <article class="group">
    <% if article.featured_image.attached? %>
      <%= link_to article_path(article), tabindex: "-1", "aria-hidden": "true" do %>
        <div class="aspect-16/10 overflow-hidden rounded-md bg-gray-100 dark:bg-gray-800 mb-3">
          <%= image_tag article.featured_image.variant(:thumb),
              class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 motion-reduce:transform-none",
              alt: t.title, loading: "lazy", width: 400, height: 250 %>
        </div>
      <% end %>
    <% end %>
    <%= link_to article_path(article),
        class: "focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 rounded" do %>
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 leading-snug font-serif">
        <%= t.title %>
      </h3>
    <% end %>
    <% if article.published_at %>
      <time class="text-xs text-gray-600 dark:text-gray-400 mt-1 block" datetime="<%= article.published_at.iso8601 %>">
        <%= article.published_at.strftime("%b %-d, %Y") %>
      </time>
    <% end %>
  </article>
<% end %>
