<%# Hero-treatment card for the top story on a section front (page 1 of
    category / location / tag indexes). Slightly subdued vs the homepage hero
    so the homepage stays the visual peak.
    Locals:
      article: required %>
<% t = article.translation_for(I18n.locale) || article.translations.first %>
<% if t %>
  <article class="mb-10 pb-10 border-b border-gray-200 dark:border-gray-800">
    <%= link_to article_path(article), class: "block group" do %>
      <% if article.featured_image.attached? %>
        <div class="aspect-16/10 overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-800 mb-4">
          <%= image_tag article.featured_image.variant(:large),
              class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 motion-reduce:transform-none",
              alt: article.featured_image_caption.presence || t.title,
              width: 1200, height: 750 %>
        </div>
      <% end %>
      <div class="flex items-center gap-2">
        <% if article.breaking? %>
          <span class="text-xs font-bold text-red-600 dark:text-red-400 uppercase tracking-wide">Breaking</span>
        <% end %>
      </div>
      <h2 class="mt-2 text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-tight font-serif">
        <%= t.title %>
      </h2>
      <% if t.dek.present? %>
        <p class="mt-3 text-lg text-gray-700 dark:text-gray-300 leading-relaxed"><%= t.dek %></p>
      <% end %>
      <div class="mt-4 flex items-center text-sm text-gray-600 dark:text-gray-400">
        <span>By <%= article.author.name %></span>
        <span class="mx-2" aria-hidden="true">·</span>
        <time datetime="<%= article.published_at.iso8601 %>"><%= article.published_at.strftime("%B %-d, %Y") %></time>
      </div>
    <% end %>
  </article>
<% end %>
