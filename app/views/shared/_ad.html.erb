<%
  # Disclosure label is always shown — required for native-ad transparency and
  # also serves as the screen-reader label so visitors can identify (and skip)
  # ad regions.
  disclosure = ad.sponsor_label.presence || "Sponsored"
%>
<aside class="ad-unit py-3 text-center"
       aria-label="<%= disclosure %>"
       data-zone="<%= ad.placement_zone %>">
  <% if ad.ad_type == "direct" %>
    <% if ad.image.attached? %>
      <%= link_to ad_click_path(ad), target: ad.link_target, rel: "noopener noreferrer sponsored nofollow" do %>
        <%= image_tag ad.image.variant(resize_to_limit: [ 970, 250 ]),
            alt: disclosure,
            class: "inline-block max-w-full h-auto",
            loading: "lazy",
            decoding: "async",
            fetchpriority: "low" %>
      <% end %>
    <% end %>
  <% else %>
    <%= raw ad.script_code %>
  <% end %>
  <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mt-1">
    <%= disclosure %>
  </p>
</aside>
