<% article_url_str = article_url(article) %>
<% encoded_url   = ERB::Util.url_encode(article_url_str) %>
<% encoded_title = ERB::Util.url_encode(article.title) %>

<div class="flex items-center gap-3 mt-6 pt-6 border-t border-gray-200">
  <span class="text-sm font-medium text-gray-500">Share:</span>

  <%# X / Twitter %>
  <a href="https://twitter.com/intent/tweet?url=<%= encoded_url %>&text=<%= encoded_title %>"
     target="_blank"
     rel="noopener noreferrer"
     class="inline-flex items-center gap-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50"
     aria-label="Share on X">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
    X
  </a>

  <%# Facebook %>
  <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encoded_url %>"
     target="_blank"
     rel="noopener noreferrer"
     class="inline-flex items-center gap-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50"
     aria-label="Share on Facebook">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
    Facebook
  </a>

  <%# Copy link %>
  <div data-controller="clipboard" data-clipboard-text-value="<%= article_url_str %>">
    <button data-clipboard-target="button"
            data-action="click->clipboard#copy"
            type="button"
            class="inline-flex items-center gap-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/>
      </svg>
      Copy link
    </button>
  </div>
</div>
