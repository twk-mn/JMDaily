<% t = article.translation_for(I18n.locale) || article.translations.first %>
<% if t %>
<article class="border-b border-gray-100 dark:border-gray-800 pb-3">
  <%= link_to article_path(article), class: "group" do %>
    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
      <%= t.title %>
    </h3>
  <% end %>
  <div class="mt-1 text-xs text-gray-600 dark:text-gray-400">
    <time datetime="<%= article.published_at.iso8601 %>"><%= article.published_at.strftime("%b %-d") %></time>
  </div>
</article>
<% end %>
