<% cat_name = @category.localized_name %>
<% cat_desc = @category.localized_description %>
<% content_for :title, cat_name %>
<% lead = @articles.first; if lead&.featured_image&.attached? %>
  <% content_for :og_image, url_for(lead.featured_image) %>
<% end %>

<% content_for :head do %>
  <%= render "shared/collection_jsonld",
      name: cat_name,
      description: cat_desc,
      url: canonical_url_for_current_request,
      articles: @articles %>
<% end %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/index_header",
      title: cat_name,
      description: cat_desc,
      count: @pagy.count,
      breadcrumbs: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: cat_name, url: request.path }
      ] %>

  <%= render "shared/paginated_article_list",
      articles: @articles,
      pagy: @pagy,
      empty_heading: "No articles in this category yet.",
      empty_body: "Check back soon — we publish every weekday." %>
</div>
