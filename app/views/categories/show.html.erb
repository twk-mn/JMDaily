<% content_for :title, @category.name %>
<% lead = @articles.first; if lead&.featured_image&.attached? %>
  <% content_for :og_image, url_for(lead.featured_image) %>
<% end %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/index_header",
      title: @category.name,
      description: @category.description,
      count: @pagy.count,
      breadcrumbs: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: @category.name, url: request.path }
      ] %>

  <% if @articles.any? %>
    <% lead, *rest = @pagy.page == 1 ? @articles.to_a : [ nil, *@articles ] %>

    <% if lead %>
      <%= render "shared/lead_story_card", article: lead %>
    <% end %>

    <% if rest.any? %>
      <div class="space-y-8">
        <% rest.each do |article| %>
          <%= render "shared/article_card", article: article %>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/pagination", pagy: @pagy %>
  <% else %>
    <%= render "shared/empty_state",
        heading: "No articles in this category yet.",
        body: "Check back soon — we publish every weekday." %>
  <% end %>
</div>
