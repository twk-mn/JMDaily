<% frame_id = "newsletter-signup-home" %>
<% input_id = "home-newsletter-email" %>
<section class="my-12 border-t border-gray-200 dark:border-gray-800 pt-10">
  <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl px-6 py-8 sm:px-10 sm:py-12 max-w-2xl mx-auto text-center">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 font-serif">Get the Joetsu-Myoko Daily</h2>
    <p class="mt-2 text-gray-700 dark:text-gray-300">Weekly roundup of the news that matters from our corner of Niigata. No spam, unsubscribe any time.</p>
    <div class="mt-6 max-w-md mx-auto text-left">
      <%= turbo_frame_tag frame_id do %>
        <%= render "newsletter_subscriptions/signup_form", frame_id: frame_id, input_id: input_id %>
      <% end %>
    </div>
  </div>
</section>
