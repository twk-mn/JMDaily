<% has_joetsu = @joetsu_articles.present? %>
<% has_myoko = @myoko_articles.present? %>
<% if has_joetsu || has_myoko %>
  <section class="mb-12 border-t border-gray-200 dark:border-gray-800 pt-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
      <% if has_joetsu %>
        <div>
          <%= render "shared/section_subhead",
              title: "Joetsu",
              link: location_path("joetsu"),
              wrapper_class: "mb-4" %>
          <div class="space-y-4">
            <% @joetsu_articles.each do |article| %>
              <%= render "shared/article_card_small", article: article %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if has_myoko %>
        <div>
          <%= render "shared/section_subhead",
              title: "Myoko",
              link: location_path("myoko"),
              wrapper_class: "mb-4" %>
          <div class="space-y-4">
            <% @myoko_articles.each do |article| %>
              <%= render "shared/article_card_small", article: article %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
