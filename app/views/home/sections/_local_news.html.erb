<% if @local_news_articles.any? %>
  <section class="mb-12 border-t border-gray-200 dark:border-gray-800 pt-8">
    <div class="flex items-baseline justify-between mb-6 border-b-2 border-gray-900 dark:border-gray-100 pb-2">
      <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100 uppercase tracking-wider">
        <%= link_to "Local News", news_path, class: "hover:text-indigo-600 dark:hover:text-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
      </h2>
      <%= link_to "See all", news_path, class: "text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300" %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @local_news_articles.each do |article| %>
        <%= render "shared/related_card", article: article %>
      <% end %>
    </div>
  </section>
<% end %>
