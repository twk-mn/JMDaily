<% if @local_news_articles.any? %>
  <section class="mb-12 border-t border-gray-200 dark:border-gray-800 pt-8">
    <%= render "shared/section_subhead",
        title: "Local News",
        link: news_path,
        meta: link_to("See all", news_path, class: "text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300") %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @local_news_articles.each do |article| %>
        <%= render "shared/related_card", article: article %>
      <% end %>
    </div>
  </section>
<% end %>
