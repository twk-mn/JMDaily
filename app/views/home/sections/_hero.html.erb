<% lead = @lead_story %>
<% lead_t = lead && (lead.translation_for(I18n.locale) || lead.translations.first) %>
<% if lead && lead_t %>
  <section class="mb-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
      <div class="lg:col-span-2">
        <%= link_to article_path(lead), class: "block group" do %>
          <% if lead.featured_image.attached? %>
            <div class="aspect-16/10 overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-800 mb-4">
              <%= image_tag lead.featured_image.variant(:large),
                  class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 motion-reduce:transform-none",
                  alt: lead.effective_alt_text(lead_t),
                  width: 1200, height: 750 %>
            </div>
          <% end %>
          <span class="text-sm font-medium text-indigo-600 dark:text-indigo-400 uppercase tracking-wide">
            <%= lead.category.name %><% if lead.type_label %> <span class="text-gray-500 dark:text-gray-400">· <%= lead.type_label %></span><% end %>
          </span>
          <h2 class="mt-2 text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-tight font-serif">
            <%= lead_t.title %>
          </h2>
          <% if lead_t.dek.present? %>
            <p class="mt-3 text-lg text-gray-700 dark:text-gray-300 leading-relaxed"><%= lead_t.dek %></p>
          <% end %>
          <div class="mt-4 flex items-center text-sm text-gray-600 dark:text-gray-400">
            <span>By <%= lead.author.name %></span>
            <span class="mx-2" aria-hidden="true">·</span>
            <%= article_time_tag(lead.published_at, format: :long) %>
          </div>
        <% end %>
      </div>

      <% if @secondary_stories.any? %>
        <aside class="lg:col-span-1 lg:border-l lg:border-gray-200 dark:lg:border-gray-800 lg:pl-8 space-y-6" aria-label="Top stories">
          <% @secondary_stories.each do |article| %>
            <% t = article.translation_for(I18n.locale) || article.translations.first %>
            <% next unless t %>
            <article class="pb-6 border-b border-gray-200 dark:border-gray-800 last:border-b-0 last:pb-0">
              <%= link_to article_path(article), class: "group flex gap-4" do %>
                <% if article.featured_image.attached? %>
                  <div class="shrink-0 w-24 sm:w-28">
                    <div class="aspect-16/10 overflow-hidden rounded-md bg-gray-100 dark:bg-gray-800">
                      <%= image_tag article.featured_image.variant(:thumb),
                          class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 motion-reduce:transform-none",
                          alt: article.effective_alt_text(t),
                          loading: "lazy", width: 400, height: 250 %>
                    </div>
                  </div>
                <% end %>
                <div class="flex-1 min-w-0">
                  <span class="text-xs font-medium text-indigo-600 dark:text-indigo-400 uppercase tracking-wide">
                    <%= article.category.name %><% if article.type_label %> <span class="text-gray-500 dark:text-gray-400">· <%= article.type_label %></span><% end %>
                  </span>
                  <h3 class="mt-1 text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug font-serif">
                    <%= t.title %>
                  </h3>
                  <div class="mt-1 text-xs text-gray-600 dark:text-gray-400">
                    <%= article_time_tag(article.published_at, format: :short) %>
                  </div>
                </div>
              <% end %>
            </article>
          <% end %>
        </aside>
      <% end %>
    </div>
  </section>
<% end %>
