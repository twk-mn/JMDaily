<% if @lead_story&.featured_image&.attached? %>
  <% content_for :og_image, url_for(@lead_story.featured_image) %>
<% end %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

  <!-- Breaking news strip -->
  <% if @breaking_articles.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 mb-8">
      <span class="inline-block bg-red-600 text-white text-xs font-bold uppercase px-2 py-0.5 rounded mr-2">Breaking</span>
      <% @breaking_articles.each_with_index do |article, i| %>
        <%= link_to article.title, article_path(article), class: "text-sm font-medium text-red-900 hover:text-red-700" %>
        <% unless i == @breaking_articles.length - 1 %>
          <span class="text-red-300 mx-2">·</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Lead story -->
  <% if @lead_story %>
    <section class="mb-12">
      <%= link_to article_path(@lead_story), class: "block group" do %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
          <% if @lead_story.featured_image.attached? %>
            <div class="aspect-[16/10] overflow-hidden rounded-lg bg-gray-100">
              <%= image_tag @lead_story.featured_image.variant(:medium),
                  class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300",
                  alt: @lead_story.featured_image_caption.presence || @lead_story.title,
                  width: 800, height: 500 %>
            </div>
          <% end %>
          <div>
            <span class="text-sm font-medium text-indigo-600 uppercase tracking-wide"><%= @lead_story.category.name %></span>
            <h2 class="mt-2 text-3xl sm:text-4xl font-bold text-gray-900 group-hover:text-indigo-600 transition-colors leading-tight" style="font-family: Georgia, serif;">
              <%= @lead_story.title %>
            </h2>
            <% if @lead_story.dek.present? %>
              <p class="mt-3 text-lg text-gray-600 leading-relaxed"><%= @lead_story.dek %></p>
            <% end %>
            <div class="mt-4 flex items-center text-sm text-gray-500">
              <span>By <%= @lead_story.author.name %></span>
              <span class="mx-2">·</span>
              <time datetime="<%= @lead_story.published_at.iso8601 %>"><%= @lead_story.published_at.strftime("%B %-d, %Y") %></time>
            </div>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

  <%= ad_for("homepage_mid") %>

  <div class="border-t border-gray-200 pt-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Latest news -->
      <div class="lg:col-span-2">
        <h2 class="text-xl font-bold text-gray-900 mb-6 uppercase tracking-wider text-sm border-b-2 border-gray-900 pb-2">Latest News</h2>
        <div class="space-y-8">
          <% @latest_articles.each do |article| %>
            <%= render "shared/article_card", article: article %>
          <% end %>
        </div>

        <% if @latest_articles.empty? && @lead_story.nil? %>
          <div class="text-center py-16">
            <p class="text-gray-500 text-lg">No articles published yet.</p>
            <p class="text-gray-400 mt-2">Check back soon for local news from Joetsu and Myoko.</p>
          </div>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-10">
        <!-- Joetsu section -->
        <% if @joetsu_articles.present? %>
          <div>
            <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider border-b-2 border-gray-900 pb-2 mb-4">
              <%= link_to "Joetsu", location_path("joetsu"), class: "hover:text-indigo-600" %>
            </h2>
            <div class="space-y-4">
              <% @joetsu_articles.each do |article| %>
                <%= render "shared/article_card_small", article: article %>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Myoko section -->
        <% if @myoko_articles.present? %>
          <div>
            <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider border-b-2 border-gray-900 pb-2 mb-4">
              <%= link_to "Myoko", location_path("myoko"), class: "hover:text-indigo-600" %>
            </h2>
            <div class="space-y-4">
              <% @myoko_articles.each do |article| %>
                <%= render "shared/article_card_small", article: article %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
