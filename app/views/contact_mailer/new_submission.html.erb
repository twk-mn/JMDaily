<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; color: #111;">
  <p style="font-size: 12px; color: #888; margin-bottom: 24px; border-bottom: 1px solid #eee; padding-bottom: 12px;">
    New message via jmdaily.com contact form
  </p>

  <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 14px;">
    <tr>
      <td style="padding: 6px 12px 6px 0; color: #666; white-space: nowrap; vertical-align: top;">From</td>
      <td style="padding: 6px 0; font-weight: bold;"><%= @submission.name %></td>
    </tr>
    <tr>
      <td style="padding: 6px 12px 6px 0; color: #666; white-space: nowrap; vertical-align: top;">Email</td>
      <td style="padding: 6px 0;"><a href="mailto:<%= @submission.email %>" style="color: #4f46e5;"><%= @submission.email %></a></td>
    </tr>
    <% if @submission.subject.present? %>
    <tr>
      <td style="padding: 6px 12px 6px 0; color: #666; white-space: nowrap; vertical-align: top;">Subject</td>
      <td style="padding: 6px 0;"><%= @submission.subject %></td>
    </tr>
    <% end %>
    <tr>
      <td style="padding: 6px 12px 6px 0; color: #666; white-space: nowrap; vertical-align: top;">Received</td>
      <td style="padding: 6px 0; color: #888;"><%= @submission.created_at.strftime("%-d %b %Y at %-I:%M %p UTC") %></td>
    </tr>
  </table>

  <div style="background: #f9f9f9; border-left: 3px solid #4f46e5; padding: 16px; font-size: 15px; line-height: 1.6; white-space: pre-wrap;"><%= @submission.message %></div>

  <div style="margin-top: 24px;">
    <a href="mailto:<%= @submission.email %>?subject=Re: <%= @submission.subject %>"
       style="display: inline-block; background: #4f46e5; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-size: 14px; font-weight: bold;">
      Reply to <%= @submission.name %>
    </a>
  </div>

  <p style="margin-top: 32px; font-size: 12px; color: #aaa; border-top: 1px solid #eee; padding-top: 12px;">
    View in admin: <%= link_to "Open message", admin_contact_submission_url(@submission), style: "color: #4f46e5;" %>
  </p>
</div>
