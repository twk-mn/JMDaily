<% content_for :title, @location.name %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/index_header",
      title: @location.name,
      description: @location.description,
      count: @pagy.count,
      breadcrumbs: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: @location.name, url: request.path }
      ] %>

  <% if @articles.any? %>
    <div class="space-y-8">
      <% @articles.each do |article| %>
        <%= render "shared/article_card", article: article %>
      <% end %>
    </div>

    <%= render "shared/pagination", pagy: @pagy %>
  <% else %>
    <%= render "shared/empty_state",
        heading: "No articles for this location yet.",
        body: "Check back soon — we're always adding new coverage." %>
  <% end %>
</div>
