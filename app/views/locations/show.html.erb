<% content_for :title, @location.name %>

<% content_for :head do %>
  <%= render "shared/collection_jsonld",
      name: @location.name,
      description: @location.description,
      url: canonical_url_for_current_request,
      articles: @articles %>
<% end %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/index_header",
      title: @location.name,
      description: @location.description,
      count: @pagy.count,
      breadcrumbs: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: @location.name, url: request.path }
      ] %>

  <%= render "shared/paginated_article_list",
      articles: @articles,
      pagy: @pagy,
      empty_heading: "No articles for this location yet.",
      empty_body: "Check back soon — we're always adding new coverage." %>
</div>
