<% content_for :title, @author.name %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/breadcrumbs", items: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: @author.name, url: request.path }
      ] %>

  <header class="mb-8 flex items-start gap-6">
    <% if @author.photo.attached? %>
      <%= image_tag @author.photo.variant(:thumb),
          class: "w-24 h-24 rounded-full object-cover shrink-0",
          alt: @author.name,
          width: 96, height: 96 %>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 font-serif"><%= @author.name %></h1>
      <% if @author.role_title.present? %>
        <p class="text-lg text-indigo-600 dark:text-indigo-400 font-medium"><%= @author.role_title %></p>
      <% end %>
      <% if @author.bio.present? %>
        <p class="mt-2 text-gray-700 dark:text-gray-300 leading-relaxed"><%= @author.bio %></p>
      <% end %>
      <div class="mt-3 flex items-center gap-4">
        <% if @author.twitter_url.present? %>
          <%= link_to "Twitter", @author.twitter_url, class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white", target: "_blank", rel: "noopener" %>
        <% end %>
        <% if @author.website_url.present? %>
          <%= link_to "Website", @author.website_url, class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white", target: "_blank", rel: "noopener" %>
        <% end %>
      </div>
    </div>
  </header>

  <div class="border-t border-gray-200 dark:border-gray-800 pt-8">
    <%= render "shared/section_subhead",
        title: "Articles by #{@author.name}",
        meta: (@pagy.count.positive? ? content_tag(:span, pluralize(@pagy.count, "article"), class: "text-xs text-gray-600 dark:text-gray-400") : nil) %>

    <% if @articles.any? %>
      <% lead, *rest = @pagy.page == 1 ? @articles.to_a : [ nil, *@articles ] %>

      <% if lead %>
        <%= render "shared/lead_story_card", article: lead %>
      <% end %>

      <% if rest.any? %>
        <div class="space-y-8">
          <% rest.each do |article| %>
            <%= render "shared/article_card", article: article %>
          <% end %>
        </div>
      <% end %>

      <%= render "shared/pagination", pagy: @pagy %>
    <% else %>
      <%= render "shared/empty_state", heading: "No published articles yet." %>
    <% end %>
  </div>
</div>
