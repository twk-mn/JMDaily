<% author_role = @author.localized_role_title %>
<% author_bio  = @author.localized_bio %>
<% content_for :title, @author.name %>
<%
  meta_bits = []
  meta_bits << author_role if author_role.present?
  meta_bits << Setting.site_name
  meta_bits << author_bio.to_s.squish.truncate(160) if author_bio.present?
%>
<% content_for :meta_description, meta_bits.join(" — ") %>
<% content_for :og_type, "profile" %>
<% if @author.photo.attached? %>
  <% content_for :og_image, url_for(@author.photo) %>
<% end %>

<% content_for :head do %>
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": @author.name,
      "url": author_url(@author, slug: @author.slug),
      "jobTitle": author_role.presence,
      "description": author_bio.presence,
      "image": (@author.photo.attached? ? url_for(@author.photo) : nil),
      "sameAs": Author::SOCIAL_LINK_FIELDS.filter_map { |attr, _| safe_external_url(@author.public_send(attr)) }.presence,
      "worksFor": {
        "@type": "Organization",
        "name": Setting.site_name
      }
    }.compact.to_json) %>
  </script>
<% end %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/breadcrumbs", items: [
        { name: t("nav.home", default: "Home"), url: locale_root_path },
        { name: @author.name, url: request.path }
      ] %>

  <header class="mb-8 flex items-start gap-6">
    <% if @author.photo.attached? %>
      <%= image_tag @author.photo.variant(:thumb),
          class: "w-24 h-24 rounded-full object-cover shrink-0",
          alt: @author.name,
          width: 96, height: 96 %>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 font-serif"><%= @author.name %></h1>
      <% if author_role.present? %>
        <p class="text-lg text-indigo-600 dark:text-indigo-400 font-medium"><%= author_role %></p>
      <% end %>
      <% if author_bio.present? %>
        <p class="mt-2 text-gray-700 dark:text-gray-300 leading-relaxed"><%= author_bio %></p>
      <% end %>
      <% social_links = Author::SOCIAL_LINK_FIELDS.filter_map { |attr, label|
           href = safe_external_url(@author.public_send(attr))
           [ label, href ] if href
         } %>
      <% if social_links.any? %>
        <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1">
          <% social_links.each do |label, href| %>
            <%= link_to label, href,
                class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white",
                target: "_blank", rel: "noopener noreferrer" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </header>

  <div class="border-t border-gray-200 dark:border-gray-800 pt-8">
    <%= render "shared/section_subhead",
        title: "Articles by #{@author.name}",
        meta: (@pagy.count.positive? ? content_tag(:span, pluralize(@pagy.count, "article"), class: "text-xs text-gray-600 dark:text-gray-400") : nil) %>

    <%= render "shared/paginated_article_list",
        articles: @articles,
        pagy: @pagy,
        empty_heading: "No published articles yet." %>
  </div>
</div>
