<% content_for :title, @author.name %>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <header class="mb-8 flex items-start gap-6">
    <% if @author.photo.attached? %>
      <%= image_tag @author.photo.variant(:thumb),
          class: "w-24 h-24 rounded-full object-cover flex-shrink-0",
          alt: @author.name,
          width: 96, height: 96 %>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-gray-900" style="font-family: Georgia, serif;"><%= @author.name %></h1>
      <% if @author.role_title.present? %>
        <p class="text-lg text-indigo-600 font-medium"><%= @author.role_title %></p>
      <% end %>
      <% if @author.bio.present? %>
        <p class="mt-2 text-gray-600 leading-relaxed"><%= @author.bio %></p>
      <% end %>
      <div class="mt-3 flex items-center gap-4">
        <% if @author.twitter_url.present? %>
          <%= link_to "Twitter", @author.twitter_url, class: "text-sm text-gray-500 hover:text-gray-700", target: "_blank", rel: "noopener" %>
        <% end %>
        <% if @author.website_url.present? %>
          <%= link_to "Website", @author.website_url, class: "text-sm text-gray-500 hover:text-gray-700", target: "_blank", rel: "noopener" %>
        <% end %>
      </div>
    </div>
  </header>

  <div class="border-t border-gray-200 pt-8">
    <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider border-b-2 border-gray-900 pb-2 mb-6">Articles by <%= @author.name %></h2>
    <div class="space-y-8">
      <% @articles.each do |article| %>
        <%= render "shared/article_card", article: article %>
      <% end %>
    </div>

    <% if @articles.empty? %>
      <p class="text-center py-16 text-gray-500">No published articles yet.</p>
    <% end %>

    <% if @pagy.pages > 1 %>
      <nav class="mt-8 flex justify-center">
        <%== @pagy.series_nav(self) %>
      </nav>
    <% end %>
  </div>
</div>
