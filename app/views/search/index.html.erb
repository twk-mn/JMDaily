<% content_for :title, @query.present? ? "Search: #{@query}" : "Search" %>
<% content_for :meta_robots, "noindex,follow" %>

<%
  highlight_phrases = @japanese ? [ @query ] : @query.to_s.split
  mark_class = "bg-yellow-100 dark:bg-yellow-700/40 text-inherit rounded px-0.5"
%>

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6 font-serif">Search</h1>

  <%= form_with url: search_path, method: :get, class: "mb-6 max-w-lg", role: "search" do %>
    <div class="flex gap-2">
      <label for="search-q" class="sr-only">Search articles</label>
      <input type="search" id="search-q" name="q" value="<%= @query %>" placeholder="Search articles..."
             class="block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500"
             autofocus>
      <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Search</button>
    </div>
  <% end %>

  <% if @query.present? %>
    <% if @japanese %>
      <p class="mb-4 inline-flex items-center gap-1.5 text-xs text-gray-700 dark:text-gray-300">
        <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
        </svg>
        Searching Japanese content
      </p>
    <% end %>

    <% if @articles.any? %>
      <p class="text-sm text-gray-700 dark:text-gray-300 mb-4">
        <%= pluralize(@total_count, "result") %> for &ldquo;<strong><%= @query %></strong>&rdquo;<%
          if @selected_category
        %> in <%= @selected_category.name %> &middot;
          <%= link_to "Clear filter", search_path(q: @query),
              class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
        <% end %>
      </p>

      <% if @category_counts.size > 1 %>
        <nav aria-label="Filter by category" class="mb-6 flex flex-wrap gap-2">
          <%
            all_classes = "rounded-full px-3 py-1 text-xs font-medium transition-colors #{
              @selected_category ?
                'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700' :
                'bg-indigo-600 text-white'
            }"
          %>
          <%= link_to "All (#{@total_count})", search_path(q: @query),
              class: all_classes,
              aria: { current: @selected_category ? nil : "true" } %>
          <% @category_counts.each do |category, count| %>
            <%
              selected = @selected_category == category
              chip_classes = "rounded-full px-3 py-1 text-xs font-medium transition-colors #{
                selected ?
                  'bg-indigo-600 text-white' :
                  'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700'
              }"
            %>
            <%= link_to "#{category.name} (#{count})", search_path(q: @query, category: category.slug),
                class: chip_classes,
                aria: { current: selected ? "true" : nil } %>
          <% end %>
        </nav>
      <% end %>

      <div class="space-y-8">
        <% @articles.each do |article| %>
          <% t = article.translation_for(I18n.locale) || article.translations.first %>
          <% next unless t %>
          <article class="flex gap-4">
            <% if article.featured_image.attached? %>
              <div class="shrink-0 w-32 sm:w-48">
                <%= link_to article_path(article) do %>
                  <div class="aspect-16/10 overflow-hidden rounded-md bg-gray-100 dark:bg-gray-800">
                    <%= image_tag article.featured_image.variant(:thumb),
                        class: "w-full h-full object-cover hover:scale-105 transition-transform duration-300 motion-reduce:transform-none",
                        alt: article.featured_image_caption.presence || t.title,
                        loading: "lazy",
                        width: 400, height: 250 %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs font-medium text-indigo-600 dark:text-indigo-400 uppercase tracking-wide"><%= article.category.name %></span>
                <% if article.breaking? %>
                  <span class="text-xs font-bold text-red-600 dark:text-red-400 uppercase">Breaking</span>
                <% end %>
              </div>
              <%= link_to article_path(article), class: "group" do %>
                <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug font-serif">
                  <%= highlight(t.title, highlight_phrases, highlighter: %(<mark class="#{mark_class}">\\1</mark>)) %>
                </h3>
              <% end %>
              <% if t.dek.present? %>
                <p class="mt-1 text-sm text-gray-700 dark:text-gray-300 line-clamp-2">
                  <%= highlight(t.dek, highlight_phrases, highlighter: %(<mark class="#{mark_class}">\\1</mark>)) %>
                </p>
              <% end %>
              <div class="mt-2 flex items-center text-xs text-gray-600 dark:text-gray-400">
                <span>By <%= article.author.name %></span>
                <span class="mx-1.5" aria-hidden="true">&middot;</span>
                <time datetime="<%= article.published_at.iso8601 %>"><%= article.published_at.strftime("%B %-d, %Y") %></time>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <%= render "shared/pagination", pagy: @pagy %>
    <% else %>
      <%= render "shared/empty_state",
          heading: %(No results found for "#{@query}"),
          body: "Try different keywords or browse the latest news." %>
    <% end %>
  <% end %>
</div>
