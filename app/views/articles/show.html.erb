<% content_for :title, @article.effective_seo_title(@translation) %>
<% content_for :meta_description, @article.effective_meta_description(@translation) %>
<% content_for :og_type, "article" %>
<% if @article.featured_image.attached? %>
  <% content_for :og_image, url_for(@article.featured_image) %>
<% end %>
<% if @article.canonical_url.present? %>
  <% content_for :canonical_url, @article.canonical_url %>
<% end %>

<% breadcrumb_items = [
  { name: t("nav.home", default: "Home"), url: locale_root_path },
  { name: @article.category.name, url: "/#{I18n.locale}/#{@article.category.slug}" },
  { name: @translation.title, url: article_url(@article) }
] %>

<% content_for :head do %>
  <!-- Article Schema -->
  <script type="application/ld+json">
    <%= raw(@json_ld.to_json) %>
  </script>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json">
    <%= raw({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumb_items.each_with_index.map { |item, i|
        { "@type": "ListItem", "position": i + 1, "name": item[:name], "item": item[:url] }
      }
    }.to_json) %>
  </script>

  <%# Alternate language links for SEO %>
  <% @article.translations.each do |t| %>
    <link rel="alternate" hreflang="<%= t.locale %>" href="<%= article_url(t, locale: t.locale) %>">
  <% end %>
<% end %>

<% if !@article.published? && current_user %>
  <%= render "shared/preview_banner", article: @article %>
<% end %>

<article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/breadcrumbs", items: breadcrumb_items %>

  <!-- Article header -->
  <header class="mb-8">
    <div class="flex items-center gap-2 mb-3">
      <%= link_to @article.category.name, "/#{I18n.locale}/#{@article.category.slug}",
          class: "text-sm font-medium text-indigo-600 dark:text-indigo-400 uppercase tracking-wide hover:text-indigo-800 dark:hover:text-indigo-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 rounded" %>
      <% if @article.breaking? %>
        <span class="bg-red-600 text-white text-xs font-bold uppercase px-2 py-0.5 rounded">Breaking</span>
      <% end %>
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 leading-tight font-serif">
      <%= @translation.title %>
    </h1>

    <% if @translation.dek.present? %>
      <p class="mt-4 text-xl text-gray-700 dark:text-gray-300 leading-relaxed"><%= @translation.dek %></p>
    <% end %>

    <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-600 dark:text-gray-400 border-t border-b border-gray-200 dark:border-gray-800 py-4">
      <div class="flex items-center gap-2">
        <% if @article.author.photo.attached? %>
          <%= image_tag @article.author.photo.variant(:small),
              class: "w-8 h-8 rounded-full object-cover",
              alt: @article.author.name,
              width: 48, height: 48 %>
        <% end %>
        <span>By <%= link_to @article.author.name, author_path(@article.author, slug: @article.author.slug),
            class: "font-medium text-gray-900 dark:text-gray-100 hover:text-indigo-600 dark:hover:text-indigo-400" %></span>
      </div>
      <% if @article.published_at %>
        <time datetime="<%= @article.published_at.iso8601 %>">
          Published <%= @article.published_at.strftime("%B %-d, %Y at %-I:%M %p") %>
        </time>
      <% end %>
      <span class="text-gray-400 dark:text-gray-600" aria-hidden="true">·</span>
      <span><%= @article.reading_time(@translation) %> min read</span>
      <% if @article.published_at && @article.updated_at > @article.published_at + 1.hour %>
        <span class="text-gray-400 dark:text-gray-600" aria-hidden="true">·</span>
        <time datetime="<%= @article.updated_at.iso8601 %>">
          Updated <%= @article.updated_at.strftime("%B %-d, %Y") %>
        </time>
      <% end %>

      <%# Language switcher — link to other available translations %>
      <% if @other_translations.any? %>
        <span class="text-gray-400 dark:text-gray-600" aria-hidden="true">·</span>
        <% @other_translations.each do |t| %>
          <% lang = SiteLanguage.iso_option(t.locale) %>
          <%= link_to (lang ? lang[:native_name] : t.locale.upcase),
              article_path(t, locale: t.locale),
              lang: t.locale,
              class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300 text-xs font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 rounded" %>
        <% end %>
      <% end %>
    </div>
  </header>

  <!-- Featured image -->
  <% if @article.featured_image.attached? %>
    <figure class="mb-8">
      <%= image_tag @article.featured_image.variant(:large),
          class: "w-full rounded-lg",
          alt: @article.featured_image_alt.presence || @article.featured_image_caption.presence || @translation.title,
          width: 1200, height: 800 %>
      <% if @article.featured_image_caption.present? %>
        <figcaption class="mt-2 text-sm text-gray-600 dark:text-gray-400 text-center"><%= @article.featured_image_caption %></figcaption>
      <% end %>
    </figure>
  <% end %>

  <!-- Inline ad (before body) -->
  <%= ad_for("article_inline") %>

  <!-- Article body -->
  <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-indigo-600 dark:prose-a:text-indigo-400 prose-img:rounded-lg prose-blockquote:border-l-4 prose-blockquote:border-indigo-600 dark:prose-blockquote:border-indigo-400 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-gray-800 dark:prose-blockquote:text-gray-200">
    <%= @translation.body %>
  </div>

  <!-- Context box (info / background) -->
  <% if @translation.context_box.present? && @translation.context_box.body.present? %>
    <aside class="my-8 border-l-4 border-indigo-400 dark:border-indigo-500 bg-indigo-50 dark:bg-indigo-950/40 rounded-r-lg px-6 py-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-indigo-700 dark:text-indigo-300 mb-3">Background</p>
      <div class="prose prose-sm dark:prose-invert max-w-none prose-a:text-indigo-600 dark:prose-a:text-indigo-400 text-gray-700 dark:text-gray-300">
        <%= @translation.context_box %>
      </div>
    </aside>
  <% end %>

  <!-- Article footer ad -->
  <%= ad_for("article_footer") %>

  <!-- Share buttons -->
  <%= render "shared/share_buttons", article: @article %>

  <!-- Author bio -->
  <%= render "shared/author_bio", author: @article.author %>

  <!-- Tags, locations, and sources -->
  <footer class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800 space-y-3">
    <% if @article.locations.any? %>
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-sm text-gray-600 dark:text-gray-400">Location:</span>
        <% @article.locations.each do |location| %>
          <%= link_to location.name, location_path(location),
              class: "inline-block bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 text-sm px-3 py-0.5 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700" %>
        <% end %>
      </div>
    <% end %>

    <% if @article.tags.any? %>
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-sm text-gray-600 dark:text-gray-400">Tags:</span>
        <% @article.tags.each do |tag| %>
          <%= link_to tag.name, tag_path(tag, slug: tag.slug),
              class: "inline-block bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 text-sm px-3 py-0.5 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700" %>
        <% end %>
      </div>
    <% end %>

    <!-- Sources -->
    <% if @article.sources.any? %>
      <div class="pt-2">
        <p class="text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-400 mb-2">Source<%= "s" if @article.sources.size > 1 %></p>
        <ul class="space-y-1">
          <% @article.sources.each do |source| %>
            <li class="text-sm text-gray-700 dark:text-gray-300">
              <% if (safe_url = safe_external_url(source.url)) %>
                <%= link_to source.name, safe_url,
                    target: "_blank", rel: "noopener noreferrer",
                    class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 dark:hover:text-indigo-300 underline" %>
              <% else %>
                <%= source.name %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </footer>

  <%= render "shared/comments",
      article: @article,
      approved_comments: @approved_comments,
      pending_comment_preview: @pending_comment_preview %>
</article>

<!-- More from this author -->
<% if @more_from_author.any? %>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 border-t border-gray-200 dark:border-gray-800">
    <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100 uppercase tracking-wider border-b-2 border-gray-900 dark:border-gray-100 pb-2 mb-6">
      More from <%= @article.author.name %>
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <% @more_from_author.each do |article| %>
        <%= render "shared/related_card", article: article %>
      <% end %>
    </div>
  </section>
<% end %>

<!-- Related articles -->
<% if @related_articles.any? %>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 border-t border-gray-200 dark:border-gray-800">
    <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100 uppercase tracking-wider border-b-2 border-gray-900 dark:border-gray-100 pb-2 mb-6">Related Stories</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% @related_articles.each do |article| %>
        <%= render "shared/related_card", article: article %>
      <% end %>
    </div>
  </section>
<% end %>
