<% content_for :title, @page.seo_title.presence || @page.title %>
<% if @page.meta_description.present? %>
  <% content_for :meta_description, @page.meta_description %>
<% end %>

<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8 font-serif"><%= @page.title %></h1>

  <div class="prose prose-lg dark:prose-invert max-w-none prose-a:text-indigo-600 dark:prose-a:text-indigo-400">
    <%= @page.body %>
  </div>

  <% if @page.slug == "submit-a-tip" && @tip_submission %>
    <div class="mt-12 border-t border-gray-200 dark:border-gray-800 pt-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">Send us a tip</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">Name and email are optional. We protect the confidentiality of our sources.</p>

      <%= form_with model: @tip_submission, url: submit_tip_path, class: "space-y-4 max-w-lg" do |f| %>
        <% if @tip_submission.errors.any? %>
          <div class="rounded-md bg-red-50 dark:bg-red-950/40 p-4" role="alert">
            <ul class="list-disc pl-5 text-sm text-red-700 dark:text-red-300">
              <% @tip_submission.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "Your name (optional)", class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :email, "Your email (optional)", class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <%= f.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :tip_body, "Your tip", class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <p class="text-xs text-gray-600 dark:text-gray-400 mb-1">Tell us what you know. Include as much detail as possible — what, when, where, and any relevant context.</p>
          <%= f.text_area :tip_body, required: true, rows: 6, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.submit "Send Tip", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @page.slug == "contact" && @contact_submission %>
    <div class="mt-12 border-t border-gray-200 dark:border-gray-800 pt-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Send us a message</h2>

      <%= form_with model: @contact_submission, url: contact_path, class: "space-y-4 max-w-lg" do |f| %>
        <% if @contact_submission.errors.any? %>
          <div class="rounded-md bg-red-50 dark:bg-red-950/40 p-4" role="alert">
            <ul class="list-disc pl-5 text-sm text-red-700 dark:text-red-300">
              <% @contact_submission.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <%= f.text_field :name, required: true, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <%= f.email_field :email, required: true, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :subject, class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <%= f.text_field :subject, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :message, class: "block text-sm font-medium text-gray-800 dark:text-gray-200" %>
          <%= f.text_area :message, required: true, rows: 5, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 shadow-sm text-sm px-3 py-2 border focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.submit "Send Message", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
