# Copy this file to .env for local overrides (never commit .env).
# All variables marked REQUIRED must be set in the Railway dashboard for production.

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_MASTER_KEY=        # REQUIRED — contents of config/master.key
RAILS_LOG_LEVEL=info

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=jmdaily.com     # REQUIRED — production domain (no https://)
EDITOR_EMAIL=editor@jmdaily.com  # REQUIRED — where contact/tip emails are sent

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=            # REQUIRED — provided automatically by Railway Postgres plugin

# ── Cloudflare R2 (Active Storage) ────────────────────────────────────────────
# Create an R2 bucket at dash.cloudflare.com, then generate an API token
# with "Object Read & Write" permissions.
R2_ACCOUNT_ID=           # REQUIRED — Cloudflare account ID (in R2 dashboard URL)
R2_ACCESS_KEY_ID=        # REQUIRED — R2 API token access key
R2_SECRET_ACCESS_KEY=    # REQUIRED — R2 API token secret key
R2_BUCKET=jmdaily-production  # REQUIRED — your R2 bucket name

# ── Email (Postmark) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USERNAME=           # REQUIRED — Postmark server API token
SMTP_PASSWORD=           # REQUIRED — Postmark server API token (same value)

# ── Error tracking ────────────────────────────────────────────────────────────
SENTRY_DSN=              # optional — Sentry project DSN

# ── Background jobs ───────────────────────────────────────────────────────────
JOB_CONCURRENCY=2        # number of SolidQueue worker processes
